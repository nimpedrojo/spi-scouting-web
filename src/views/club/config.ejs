<h1 class="mb-4">Configuración del club: <%= club %></h1>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">
        Usuarios del club
      </div>
      <div class="card-body">
        <% if (!users || !users.length) { %>
          <p class="text-muted mb-2">No hay usuarios asociados a este club.</p>
        <% } else { %>
          <ul class="list-group list-group-flush mb-3">
            <% users.forEach(function(u) { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>
                  <strong><%= u.name %></strong>
                  <small class="text-muted d-block"><%= u.email %></small>
                </span>
                <span class="badge bg-secondary text-uppercase">
                  <%= u.role %>
                </span>
              </li>
            <% }); %>
          </ul>
        <% } %>
        <a href="/admin/users" class="btn btn-sr-outline btn-sm">
          Gestionar usuarios
        </a>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">
        Equipos del club
      </div>
      <div class="card-body">
        <% if (!teams || !teams.length) { %>
          <p class="text-muted mb-2">Todavía no hay equipos dados de alta para este club.</p>
        <% } else { %>
          <ul class="list-group list-group-flush mb-3">
            <% teams.forEach(function(t) { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <form
                  class="d-flex flex-grow-1 gap-2 align-items-center"
                  method="POST"
                  action="/admin/club/teams/<%= t.id %>/rename"
                >
                  <input
                    type="text"
                    name="name"
                    class="form-control form-control-sm"
                    value="<%= t.name %>"
                  />
                  <button
                    type="submit"
                    class="btn btn-sm btn-primary"
                  >
                    Guardar
                  </button>
                </form>
                <form
                  method="POST"
                  action="/admin/club/teams/<%= t.id %>/delete"
                  onsubmit="return confirm('¿Seguro que quieres borrar este equipo?');"
                >
                  <button
                    type="submit"
                    class="btn btn-sm btn-outline-danger"
                  >
                    Borrar
                  </button>
                </form>
              </li>
            <% }); %>
          </ul>
        <% } %>

        <form method="POST" action="/admin/club/teams" class="row g-2 align-items-center">
          <div class="col-8">
            <input
              type="text"
              name="name"
              class="form-control form-control-sm"
              placeholder="Nuevo equipo"
              required
            />
          </div>
          <div class="col-4 d-grid">
            <button type="submit" class="btn btn-sm btn-primary">
              Añadir equipo
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mt-1">
  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">
        Jugadores del club
      </div>
      <div class="card-body">
        <% if (!players || !players.length) { %>
          <p class="text-muted mb-2">No hay jugadores registrados para este club.</p>
        <% } else { %>
          <p class="text-muted mb-2">
            Total jugadores: <strong><%= players.length %></strong>
          </p>
          <ul class="list-group list-group-flush mb-3">
            <% players.slice(0, 5).forEach(function(p) { %>
              <li class="list-group-item">
                <strong><%= p.first_name %> <%= p.last_name %></strong>
                <small class="text-muted d-block">
                  <%= p.team || 'Sin equipo' %>
                </small>
              </li>
            <% }); %>
          </ul>
          <% if (players.length > 5) { %>
            <p class="text-muted small">
              Mostrando los 5 primeros jugadores.
            </p>
          <% } %>
        <% } %>
        <a href="/admin/players" class="btn btn-sr-outline btn-sm">
          Gestionar jugadores
        </a>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">
        Informes del club
      </div>
      <div class="card-body">
        <% if (!reports || !reports.length) { %>
          <p class="text-muted mb-2">No hay informes registrados para este club.</p>
        <% } else { %>
          <p class="text-muted mb-2">
            Total informes: <strong><%= reports.length %></strong>
          </p>
          <ul class="list-group list-group-flush mb-3">
            <% reports.slice(0, 5).forEach(function(r) { %>
              <li class="list-group-item">
                <strong><%= r.player_name %> <%= r.player_surname %></strong>
                <small class="text-muted d-block">
                  <%= r.team || '' %> · <%= r.year || '' %>
                </small>
              </li>
            <% }); %>
          </ul>
          <% if (reports.length > 5) { %>
            <p class="text-muted small">
              Mostrando los 5 primeros informes.
            </p>
          <% } %>
        <% } %>
        <a href="/reports" class="btn btn-sr-outline btn-sm">
          Gestionar informes
        </a>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mt-1">
  <div class="col-lg-12">
    <div class="card h-100">
      <div class="card-header">
        Recomendaciones por año (mapeo año → opciones)
      </div>
      <div class="card-body">
        <p class="text-muted">
          Configura aquí las opciones de recomendación por año de nacimiento para este club.
          Se usarán en el desplegable de recomendación al crear informes.
        </p>

        <% if (!recommendations || !recommendations.length) { %>
          <p class="text-muted">No hay recomendaciones configuradas todavía.</p>
        <% } else { %>
          <div class="table-responsive mb-3">
            <table class="table table-sm align-middle">
              <thead>
                <tr>
                  <th style="width: 80px;">Año</th>
                  <th>Opciones (separadas por comas)</th>
                  <th style="width: 150px;" class="text-end">Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% recommendations.forEach(function(r) { %>
                  <tr>
                    <td>
                      <form
                        method="POST"
                        action="/admin/club/recommendations/<%= r.id %>/edit"
                        class="d-flex gap-2 align-items-center"
                      >
                        <input
                          type="number"
                          name="year"
                          class="form-control form-control-sm"
                          value="<%= r.year %>"
                          min="1900"
                          max="2100"
                          required
                        />
                    </td>
                    <td>
                        <input
                          type="text"
                          name="options"
                          class="form-control form-control-sm"
                          value="<%= r.options %>"
                          placeholder="Ej: JUVENIL A, JUVENIL B"
                          required
                        />
                    </td>
                    <td class="text-end">
                        <button type="submit" class="btn btn-sm btn-primary me-2">
                          Guardar
                        </button>
                      </form>
                      <form
                        method="POST"
                        action="/admin/club/recommendations/<%= r.id %>/delete"
                        class="d-inline"
                        onsubmit="return confirm('¿Seguro que quieres borrar esta fila de recomendaciones?');"
                      >
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          Borrar
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>

        <form method="POST" action="/admin/club/recommendations" class="row g-2 align-items-center">
          <div class="col-2">
            <input
              type="number"
              name="year"
              class="form-control form-control-sm"
              placeholder="Año"
              min="1900"
              max="2100"
              required
            />
          </div>
          <div class="col-7">
            <input
              type="text"
              name="options"
              class="form-control form-control-sm"
              placeholder="Opciones separadas por comas"
              required
            />
          </div>
          <div class="col-3 d-grid">
            <button type="submit" class="btn btn-sm btn-primary">
              Añadir mapeo
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
