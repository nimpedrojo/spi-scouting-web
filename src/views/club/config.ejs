<h1 class="mb-4">Configuración del club: <%= club %></h1>

<% if (clubOptions && clubOptions.length) { %>
  <div class="card mb-4">
    <div class="card-body">
      <form method="GET" action="/admin/club" class="row g-3 align-items-end">
        <div class="col-md-6">
          <label for="club_id" class="form-label">Club administrado</label>
          <select id="club_id" name="club_id" class="form-select">
            <% clubOptions.forEach((option) => { %>
              <option value="<%= option.id %>" <%= String(selectedClubId || '') === String(option.id) ? 'selected' : '' %>><%= option.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <button type="submit" class="btn btn-primary">Cambiar club</button>
        </div>
      </form>
    </div>
  </div>
<% } %>

<% if (requiresClubSelection) { %>
  <div class="alert alert-light border mb-4">
    <% if (isSuperAdmin) { %>
      Selecciona primero un club para administrar su configuración, branding, módulos y estructura operativa.
    <% } else { %>
      Debes seleccionar un club antes de continuar.
    <% } %>
  </div>
<% } %>

<div class="row g-4">
  <% if (!requiresClubSelection) { %>
  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">
        Módulos activos del club
      </div>
      <div class="card-body">
        <p class="text-muted">
          Activa solo los verticales que este club debe tener disponibles en navegación, dashboard y acceso por URL.
        </p>

        <div class="row g-3 mb-4">
          <div class="col-md-4">
            <div class="border rounded p-3 h-100">
              <div class="small text-muted text-uppercase">Activos</div>
              <div class="display-6 fw-semibold"><%= moduleSummary ? moduleSummary.active : 0 %></div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded p-3 h-100">
              <div class="small text-muted text-uppercase">Inactivos</div>
              <div class="display-6 fw-semibold"><%= moduleSummary ? moduleSummary.inactive : 0 %></div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded p-3 h-100">
              <div class="small text-muted text-uppercase">Total preparado</div>
              <div class="display-6 fw-semibold"><%= moduleSummary ? moduleSummary.total : 0 %></div>
            </div>
          </div>
        </div>

        <form method="POST" action="/admin/club/modules">
          <input type="hidden" name="club_id" value="<%= selectedClubId || '' %>" />

          <% if (modulePresets && modulePresets.length) { %>
            <div class="mb-4">
              <div class="fw-semibold mb-2">Presets rápidos</div>
              <div class="d-flex flex-wrap gap-2 mb-2">
                <% modulePresets.forEach((preset) => { %>
                  <button
                    type="submit"
                    name="module_preset"
                    value="<%= preset.key %>"
                    class="btn btn-outline-secondary btn-sm"
                  >
                    <%= preset.label %>
                  </button>
                <% }) %>
              </div>
              <div class="small text-muted">
                Usa un preset para aplicar una combinación recomendada sin marcar módulo a módulo.
              </div>
            </div>
          <% } %>

          <% if (!modules || !modules.length) { %>
            <p class="text-muted mb-3">No hay módulos configurados todavía para este club.</p>
          <% } else { %>
            <div class="vstack gap-3 mb-3">
              <% modules.forEach((moduleEntry) => { %>
                <div class="border rounded p-3">
                  <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div class="form-check flex-grow-1">
                      <input
                        class="form-check-input"
                        type="checkbox"
                        name="module_keys"
                        value="<%= moduleEntry.moduleKey %>"
                        id="module_<%= moduleEntry.moduleKey %>"
                        <%= moduleEntry.enabled ? 'checked' : '' %>
                      />
                      <label class="form-check-label fw-semibold" for="module_<%= moduleEntry.moduleKey %>">
                        <%= moduleEntry.label %>
                      </label>
                    </div>
                    <span class="badge <%= moduleEntry.enabled ? 'bg-success-subtle text-success-emphasis' : 'bg-secondary-subtle text-secondary-emphasis' %>">
                      <%= moduleEntry.enabled ? 'Activo' : 'Inactivo' %>
                    </span>
                  </div>
                  <div class="small text-muted mt-2"><%= moduleEntry.description %></div>
                  <div class="small text-muted mt-2">
                    Ruta principal:
                    <% if (moduleEntry.entryPath && moduleEntry.entryPath !== '#') { %>
                      <code><%= moduleEntry.entryPath %></code>
                    <% } else { %>
                      <span>No definida todavía</span>
                    <% } %>
                  </div>
                  <div class="small text-muted mt-2">
                    Acceso previsto: <%= moduleEntry.roleSummary || 'Pendiente de definir.' %>
                  </div>
                  <% if (moduleEntry.defaultEnabled) { %>
                    <div class="small text-muted mt-2">Módulo base recomendado para todos los clubes.</div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          <% } %>

          <button type="submit" class="btn btn-primary">Guardar selección manual</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">
        Branding del club
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/club/branding" enctype="multipart/form-data">
          <input type="hidden" name="club_id" value="<%= selectedClubId || '' %>" />

          <div class="mb-3">
            <label for="interface_color" class="form-label">Color principal del interfaz</label>
            <div class="d-flex align-items-center gap-3">
              <input
                type="color"
                class="form-control form-control-color"
                id="interface_color"
                name="interface_color"
                value="<%= clubRecord && clubRecord.interface_color ? clubRecord.interface_color : '#0F3D2E' %>"
                title="Selecciona el color principal"
              />
              <div class="small text-muted">
                Se aplicará al interfaz del club y al acabado visual de reportes e informes.
              </div>
            </div>
          </div>

          <div class="mb-3">
            <label for="crest_file" class="form-label">Escudo del club</label>
            <input
              type="file"
              class="form-control"
              id="crest_file"
              name="crest_file"
              accept="image/*"
            />
            <div class="form-text">Formatos recomendados: PNG o SVG. Tamaño máximo: 2MB.</div>
          </div>

          <% if (clubRecord && clubRecord.crest_path) { %>
            <div class="mb-3 d-flex align-items-center gap-3">
              <img
                src="<%= clubRecord.crest_path %>"
                alt="Escudo de <%= clubRecord.name %>"
                style="width:72px;height:72px;object-fit:contain;border-radius:12px;background:#fff;border:1px solid rgba(15,61,46,0.12);padding:0.4rem;"
              />
              <div>
                <div class="fw-semibold">Escudo actual</div>
                <div class="form-check mt-2">
                  <input class="form-check-input" type="checkbox" value="1" id="remove_crest" name="remove_crest" />
                  <label class="form-check-label" for="remove_crest">Eliminar escudo actual</label>
                </div>
              </div>
            </div>
          <% } %>

          <button type="submit" class="btn btn-primary">Guardar branding</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">
        Usuarios del club
      </div>
      <div class="card-body">
        <% if (!users || !users.length) { %>
          <p class="text-muted mb-2">No hay usuarios asociados a este club.</p>
        <% } else { %>
          <ul class="list-group list-group-flush mb-3">
            <% users.forEach(function(u) { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>
                  <strong><%= u.name %></strong>
                  <small class="text-muted d-block"><%= u.email %></small>
                </span>
                <span class="badge bg-secondary text-uppercase">
                  <%= u.role %>
                </span>
              </li>
            <% }); %>
          </ul>
        <% } %>
        <a href="/admin/users" class="btn btn-sr-outline btn-sm">
          Gestionar usuarios
        </a>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">
        Equipos v2 del club (Plantillas)
      </div>
      <div class="card-body">
        <% if (!v2Teams || !v2Teams.length) { %>
          <p class="text-muted mb-2">Todavía no hay equipos v2 dados de alta para este club.</p>
        <% } else { %>
          <ul class="list-group list-group-flush mb-3">
            <% v2Teams.forEach(function(t) { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>
                  <strong><%= t.name %></strong>
                  <small class="text-muted d-block"><%= t.season_name || '-' %> · <%= t.category_name || '-' %> · <%= t.section_name || '-' %></small>
                </span>
                <a href="/teams/<%= t.id %>" class="btn btn-sm btn-outline-primary">Abrir ficha</a>
              </li>
            <% }); %>
          </ul>
        <% } %>

        <div class="d-flex gap-2">
          <a href="/teams" class="btn btn-sm btn-outline-secondary">Abrir Plantillas</a>
          <a href="/teams/new" class="btn btn-sm btn-primary">Crear equipo v2</a>
        </div>
      </div>
    </div>
  </div>
  <% } %>
</div>

<% if (!requiresClubSelection) { %>
<div class="row g-4 mt-1">
  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">
        Jugadores del club
      </div>
      <div class="card-body">
        <% if (!players || !players.length) { %>
          <p class="text-muted mb-2">No hay jugadores registrados para este club.</p>
        <% } else { %>
          <p class="text-muted mb-2">
            Total jugadores: <strong><%= players.length %></strong>
          </p>
          <ul class="list-group list-group-flush mb-3">
            <% players.slice(0, 5).forEach(function(p) { %>
              <li class="list-group-item">
                <strong><%= p.first_name %> <%= p.last_name %></strong>
                <small class="text-muted d-block">
                  <%= p.relational_team_name || 'Sin equipo' %>
                </small>
              </li>
            <% }); %>
          </ul>
          <% if (players.length > 5) { %>
            <p class="text-muted small">
              Mostrando los 5 primeros jugadores.
            </p>
          <% } %>
        <% } %>
        <a href="/admin/players" class="btn btn-sr-outline btn-sm">
          Gestionar jugadores
        </a>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">
        Informes del club
      </div>
      <div class="card-body">
        <% if (!reports || !reports.length) { %>
          <p class="text-muted mb-2">No hay informes registrados para este club.</p>
        <% } else { %>
          <p class="text-muted mb-2">
            Total informes: <strong><%= reports.length %></strong>
          </p>
          <ul class="list-group list-group-flush mb-3">
            <% reports.slice(0, 5).forEach(function(r) { %>
              <li class="list-group-item">
                <strong><%= r.player_name %> <%= r.player_surname %></strong>
                <small class="text-muted d-block">
                  <%= r.team || '' %> · <%= r.year || '' %>
                </small>
              </li>
            <% }); %>
          </ul>
          <% if (reports.length > 5) { %>
            <p class="text-muted small">
              Mostrando los 5 primeros informes.
            </p>
          <% } %>
        <% } %>
        <a href="/reports" class="btn btn-sr-outline btn-sm">
          Gestionar informes
        </a>
      </div>
    </div>
  </div>
</div>
<% } %>

<div class="row g-4 mt-1">
  <div class="col-lg-12">
    <div class="card h-100">
      <div class="card-header">
        Recomendaciones por año (mapeo año → opciones)
      </div>
      <div class="card-body">
        <p class="text-muted">
          Configura aquí las opciones de recomendación por año de nacimiento para este club.
          Se usarán en el desplegable de recomendación al crear informes.
        </p>

        <% if (!recommendations || !recommendations.length) { %>
          <p class="text-muted">No hay recomendaciones configuradas todavía.</p>
        <% } else { %>
          <div class="table-responsive mb-3">
            <table class="table table-sm align-middle">
              <thead>
                <tr>
                  <th style="width: 80px;">Año</th>
                  <th>Opciones (separadas por comas)</th>
                  <th style="width: 150px;" class="text-end">Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% recommendations.forEach(function(r) { %>
                  <tr>
                    <td>
                      <form
                        method="POST"
                        action="/admin/club/recommendations/<%= r.id %>/edit"
                        class="d-flex gap-2 align-items-center"
                      >
                        <input type="hidden" name="club_id" value="<%= selectedClubId || '' %>" />
                        <input
                          type="number"
                          name="year"
                          class="form-control form-control-sm"
                          value="<%= r.year %>"
                          min="1900"
                          max="2100"
                          required
                        />
                    </td>
                    <td>
                        <input
                          type="text"
                          name="options"
                          class="form-control form-control-sm"
                          value="<%= r.options %>"
                          placeholder="Ej: JUVENIL A, JUVENIL B"
                          required
                        />
                    </td>
                    <td class="text-end">
                        <button type="submit" class="btn btn-sm btn-primary me-2">
                          Guardar
                        </button>
                      </form>
                      <form
                        method="POST"
                        action="/admin/club/recommendations/<%= r.id %>/delete"
                        class="d-inline"
                        onsubmit="return confirm('¿Seguro que quieres borrar esta fila de recomendaciones?');"
                      >
                        <input type="hidden" name="club_id" value="<%= selectedClubId || '' %>" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          Borrar
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>

        <form method="POST" action="/admin/club/recommendations" class="row g-2 align-items-center">
          <input type="hidden" name="club_id" value="<%= selectedClubId || '' %>" />
          <div class="col-2">
            <input
              type="number"
              name="year"
              class="form-control form-control-sm"
              placeholder="Año"
              min="1900"
              max="2100"
              required
            />
          </div>
          <div class="col-7">
            <input
              type="text"
              name="options"
              class="form-control form-control-sm"
              placeholder="Opciones separadas por comas"
              required
            />
          </div>
          <div class="col-3 d-grid">
            <button type="submit" class="btn btn-sm btn-primary">
              Añadir mapeo
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
