<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle || 'SoccerProcessIQ Suite' %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/styles.css" />
    <% if (activeClubBranding && activeClubBranding.interfaceColor) { %>
      <style>
        :root {
          --sr-primary: <%= activeClubBranding.interfaceColor %>;
          --sr-secondary: <%= activeClubBranding.interfaceColor %>;
          --sr-info: <%= activeClubBranding.interfaceColor %>;
        }
      </style>
    <% } %>
  </head>
  <%
    const isPmvShell = typeof productModeInfo !== 'undefined'
      && productModeInfo
      && productModeInfo.isPmvPlayerTracking;
  %>
  <body class="<%= currentUser ? 'app-shell' : 'auth-shell' %> <%= currentUser ? (isPmvShell ? 'mode-pmv' : 'mode-suite') : '' %>">
    <% if (currentUser) { %>
      <div class="app-frame">
        <%- include('partials/sidebar') %>
        <main class="app-main">
          <%- include('partials/topbar') %>
          <div class="app-content">
            <div class="app-content__inner">
              <% if (success && success.length) { %>
                <div class="alert alert-success"><%= success %></div>
              <% } %>
              <% if (error && error.length) { %>
                <div class="alert alert-danger"><%= error %></div>
              <% } %>
              <%- body %>
            </div>
          </div>
        </main>
      </div>
    <% } else { %>
      <div class="container py-4">
        <% if (success && success.length) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>
        <% if (error && error.length) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <%- body %>
      </div>
    <% } %>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
