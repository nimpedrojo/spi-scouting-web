<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Informes STV</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
      <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
          <img
            src="/img/logo-stadium.png"
            alt="Stadium Venecia"
            class="navbar-brand-logo"
          />
          <span>Informes STV</span>
        </a>
        <div class="collapse navbar-collapse">
          <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
            <% if (currentUser) { %>
            <% if (currentUser.role === 'admin') { %>
            <li class="nav-item">
              <a class="nav-link" href="/reports">Informes</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/users">Usuarios</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/players">Jugadores</a>
            </li>
            <% } %>
            <li class="nav-item">
              <a class="nav-link" href="/account">Cuenta</a>
            </li>
            <li class="nav-item">
              <form method="POST" action="/logout">
                <button class="btn btn-outline-light btn-sm" type="submit">
                  Salir
                </button>
              </form>
            </li>
            <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/login">Entrar</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/register">Registro</a>
            </li>
            <% } %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container mb-4">
      <% if (success && success.length) { %>
      <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (error && error.length) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <%- body %>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
