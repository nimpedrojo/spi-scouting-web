<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div>
    <h1 class="mb-1"><%= report.opponentName %></h1>
    <p class="text-muted mb-0">
      <%= report.competition || 'Competición pendiente' %>
      <% if (report.matchDate) { %> · <%= report.matchDate.toISOString().slice(0, 10) %><% } %>
      <% if (report.ownTeamName) { %> · Equipo propio: <%= report.ownTeamName %><% } %>
    </p>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <a href="/scouting-teams" class="btn btn-outline-secondary">Volver</a>
    <% if (permissions && permissions.canEdit) { %>
      <a href="/scouting-teams/<%= report.id %>/edit" class="btn btn-primary">Editar</a>
    <% } %>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h2 class="h5 mb-3">Ficha del informe</h2>
        <ul class="list-unstyled mb-0">
          <li><strong>Rival:</strong> <%= report.opponentName %></li>
          <li><strong>País:</strong> <%= report.opponentCountryName || '-' %></li>
          <li><strong>Competición:</strong> <%= report.competition || '-' %></li>
          <li><strong>Fecha:</strong> <%= report.matchDate ? report.matchDate.toISOString().slice(0, 10) : '-' %></li>
          <li><strong>Sistema:</strong> <%= report.systemShape || '-' %></li>
          <li><strong>Equipo propio:</strong> <%= report.ownTeamName || '-' %></li>
          <li><strong>Autor:</strong> <%= report.authorName || '-' %></li>
          <li><strong>Email:</strong> <%= report.authorEmail || '-' %></li>
          <li><strong>Actualizado:</strong> <%= report.updatedAt ? report.updatedAt.toISOString().slice(0, 10) : '-' %></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <h2 class="h5 mb-3">Análisis táctico</h2>
        <div class="mb-3">
          <h3 class="h6">Con balón</h3>
          <p class="mb-0"><%= report.styleInPossession || 'Sin información registrada.' %></p>
        </div>
        <div class="mb-3">
          <h3 class="h6">Sin balón</h3>
          <p class="mb-0"><%= report.styleOutOfPossession || 'Sin información registrada.' %></p>
        </div>
        <div class="mb-3">
          <h3 class="h6">Transiciones</h3>
          <p class="mb-0"><%= report.transitions || 'Sin información registrada.' %></p>
        </div>
        <div>
          <h3 class="h6">Balón parado</h3>
          <p class="mb-0"><%= report.setPieces || 'Sin información registrada.' %></p>
        </div>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h5 mb-3">Conclusiones</h2>
        <div class="mb-3">
          <h3 class="h6">Fortalezas</h3>
          <p class="mb-0"><%= report.strengths || 'Sin fortalezas registradas.' %></p>
        </div>
        <div class="mb-3">
          <h3 class="h6">Debilidades</h3>
          <p class="mb-0"><%= report.weaknesses || 'Sin debilidades registradas.' %></p>
        </div>
        <div class="mb-3">
          <h3 class="h6">Jugadores clave</h3>
          <p class="mb-0"><%= report.keyPlayers || 'Sin jugadores clave registrados.' %></p>
        </div>
        <div>
          <h3 class="h6">Observaciones generales</h3>
          <p class="mb-0"><%= report.generalObservations || 'Sin observaciones registradas.' %></p>
        </div>
      </div>
    </div>

    <% if (permissions && permissions.canDelete) { %>
      <form
        method="POST"
        action="/scouting-teams/<%= report.id %>/delete"
        class="mt-3"
        onsubmit="return confirm('¿Seguro que quieres borrar este informe de scouting?');"
      >
        <button type="submit" class="btn btn-outline-danger">Borrar informe</button>
      </form>
    <% } else if (permissions && permissions.canEdit) { %>
      <div class="alert alert-light border mt-3 mb-0">
        Puedes editar este informe porque eres su autor, pero el borrado queda reservado a administradores del club.
      </div>
    <% } %>
  </div>
</div>
