<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div>
    <h1 class="mb-1">SPI Planning</h1>
    <p class="text-muted mb-0">Planificación metodológica del equipo dentro de SoccerProcessIQ Suite.</p>
  </div>
  <% if (planning.selectedTeam) { %>
    <a href="/planning/plans/new?team_id=<%= planning.selectedTeam.id %>" class="btn btn-primary">Nueva planificación</a>
  <% } %>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <form method="GET" action="/planning" class="row g-3 align-items-end">
      <div class="col-md-8">
        <label for="team_id" class="form-label">Equipo</label>
        <select id="team_id" name="team_id" class="form-select">
          <% if (planning.visibleTeams && planning.visibleTeams.length) { %>
            <% planning.visibleTeams.forEach((team) => { %>
              <option value="<%= team.id %>" <%= planning.selectedTeam && String(planning.selectedTeam.id) === String(team.id) ? 'selected' : '' %>>
                <%= team.name %> · <%= team.category_name %> · <%= team.section_name %> · <%= team.season_name %>
              </option>
            <% }) %>
          <% } else { %>
            <option value="">Sin equipos disponibles</option>
          <% } %>
        </select>
      </div>
      <div class="col-md-4 d-flex gap-2">
        <button type="submit" class="btn btn-outline-secondary">Cambiar contexto</button>
        <% if (planning.selectedTeam) { %>
          <a href="/teams/<%= planning.selectedTeam.id %>" class="btn btn-outline-secondary">Volver al equipo</a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<% if (planning.selectedTeam) { %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <div class="dashboard-entry-eyebrow">Contexto de equipo</div>
          <h2 class="h4 mb-1"><%= planning.selectedTeam.name %></h2>
          <div class="text-muted">
            <%= planning.selectedTeam.category_name %> · <%= planning.selectedTeam.section_name %> · <%= planning.selectedTeam.season_name %>
          </div>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <span class="badge text-bg-light border"><%= planning.seasonPlans.length %> planificaciones</span>
          <% if (planning.activeSeason) { %>
            <span class="badge text-bg-light border">Temporada activa <%= planning.activeSeason.name %></span>
          <% } %>
        </div>
      </div>
    </div>
  </div>
<% } %>

<% if (!planning.selectedTeam) { %>
  <div class="card shadow-sm">
    <div class="card-body">
      <p class="mb-0 text-muted">No hay equipos disponibles para tu contexto actual.</p>
    </div>
  </div>
<% } else if (!planning.seasonPlans.length) { %>
  <div class="card shadow-sm">
    <div class="card-body">
      <h2 class="h5 mb-2">Sin planificación creada</h2>
      <p class="text-muted mb-3">Empieza creando una planificación de temporada para este equipo.</p>
      <a href="/planning/plans/new?team_id=<%= planning.selectedTeam.id %>" class="btn btn-primary">Crear primera planificación</a>
    </div>
  </div>
<% } else { %>
  <div class="row g-4">
    <% planning.seasonPlans.forEach((seasonPlan) => { %>
      <div class="col-xl-4 col-lg-6">
        <div class="card dashboard-entry-card h-100 shadow-sm">
          <div class="card-body d-flex flex-column">
            <div class="dashboard-entry-eyebrow">Planificación de temporada</div>
            <h3 class="h5 mb-2"><%= seasonPlan.season_label %></h3>
            <div class="small text-muted mb-3"><%= seasonPlan.planning_model %></div>

            <div class="d-flex flex-wrap gap-2 mb-3">
              <span class="badge text-bg-light border"><%= seasonPlan.microcycle_count %> microciclos</span>
              <span class="badge text-bg-light border"><%= seasonPlan.session_count %> sesiones</span>
            </div>

            <p class="small text-muted mb-3">
              <%= seasonPlan.objective || 'Sin objetivo general definido todavía.' %>
            </p>

            <div class="mt-auto d-flex gap-2 flex-wrap">
              <a href="/planning/plans/<%= seasonPlan.id %>" class="btn btn-sm btn-primary">Abrir</a>
              <a href="/planning/plans/<%= seasonPlan.id %>/edit" class="btn btn-sm btn-outline-secondary">Editar</a>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
