<%
  const activeModuleCount = Array.isArray(moduleEntries) ? moduleEntries.length : 0;
  const defaultTeamName = currentUser && (currentUser.default_team || currentUser.defaultTeam || currentUser.defaultTeamName);
  const isPmvMode = productMode && productMode.isPmvPlayerTracking;
  const showPendingByTeam = !isPmvMode
    && dashboard
    && dashboard.modules
    && dashboard.modules.scoutingPlayersEnabled
    && dashboard.pendingByTeam
    && dashboard.pendingByTeam.length;
  const recentActivity = dashboard && dashboard.recentPlayerTrackingActivity
    ? dashboard.recentPlayerTrackingActivity
    : { evaluations: [], reports: [], teams: [] };
  const pmvBrandLabel = productBranding ? productBranding.productLabel : 'PlayerTrack';
  const pmvBrandSignature = productBranding ? productBranding.productSignature : 'by ProcessIQ';
%>

<% if (isPmvMode) { %>
  <section class="pmv-dashboard-hero mb-5">
    <div class="card pmv-surface-card pmv-surface-card--hero shadow-sm border-0">
      <div class="card-body p-4 p-lg-5">
        <div class="row g-4 align-items-start">
          <div class="col-12 col-xl-8">
            <div class="mb-4 text-center text-lg-start">
              <div class="d-inline-flex align-items-center gap-2 flex-wrap mb-3">
                <span class="dashboard-kicker"><%= pmvBrandLabel %></span>
                <span class="pmv-brand-signature"><%= pmvBrandSignature %></span>
                <span class="badge rounded-pill text-bg-light border">Trabajo diario</span>
              </div>
              <h1 class="h2 mb-2">Seguimiento claro del jugador, desde el primer paso</h1>
              <p class="text-muted mb-0">Accede al flujo principal del club para evaluar, registrar actividad y revisar la evolución reciente.</p>
            </div>

            <div class="row g-4">
              <div class="col-12 col-lg-4">
                <a href="/teams" class="text-decoration-none text-reset">
                  <div class="card pmv-action-card h-100 border-0">
                    <div class="card-body p-4">
                      <div class="pmv-action-card__icon" aria-hidden="true">
                        <svg viewBox="0 0 20 20"><path d="M10 2 3 6v8l7 4 7-4V6zm0 2.2 4.8 2.74L10 9.68 5.2 6.94zM5 8.7l4 2.28v4.7l-4-2.28zm6 7v-4.7l4-2.28v4.7z"/></svg>
                      </div>
                      <div class="pmv-action-card__eyebrow">Ruta principal</div>
                      <h2 class="h4 mb-2">Entrar por equipo</h2>
                      <p class="text-muted mb-4">Abre una plantilla y entra al jugador con menos pasos.</p>
                      <div class="btn btn-primary btn-lg w-100">Ver equipos</div>
                    </div>
                  </div>
                </a>
              </div>

              <div class="col-12 col-lg-4">
                <a href="/evaluations/new" class="text-decoration-none text-reset">
                  <div class="card pmv-action-card h-100 border-0">
                    <div class="card-body p-4">
                      <div class="pmv-action-card__icon" aria-hidden="true">
                        <svg viewBox="0 0 20 20"><path d="M4 3h12v2H4zm0 4h12v2H4zm0 4h8v2H4zm0 4h8v2H4zm10.6-1.4 2.8 2.8-1.4 1.4-2.8-2.8V14h1.4z"/></svg>
                      </div>
                      <div class="pmv-action-card__eyebrow">Acción directa</div>
                      <h2 class="h4 mb-2">Evaluar jugador</h2>
                      <p class="text-muted mb-4">Registra una nueva evaluación y sigue desde la ficha.</p>
                      <div class="btn btn-primary btn-lg w-100">Nueva evaluación</div>
                    </div>
                  </div>
                </a>
              </div>

              <div class="col-12 col-lg-4">
                <a href="/reports" class="text-decoration-none text-reset">
                  <div class="card pmv-action-card h-100 border-0">
                    <div class="card-body p-4">
                      <div class="pmv-action-card__icon" aria-hidden="true">
                        <svg viewBox="0 0 20 20"><path d="M4 3h12v14H4zm2 2v2h8V5zm0 4v2h8V9zm0 4v2h5v-2z"/></svg>
                      </div>
                      <div class="pmv-action-card__eyebrow">Seguimiento</div>
                      <h2 class="h4 mb-2">Ver historial de informes</h2>
                      <p class="text-muted mb-4">Revisa lo último registrado y vuelve a cualquier jugador.</p>
                      <div class="btn btn-primary btn-lg w-100">Abrir historial</div>
                    </div>
                  </div>
                </a>
              </div>
            </div>
          </div>

          <div class="col-12 col-xl-4">
            <div class="pmv-hero-aside h-100">
              <div class="pmv-hero-aside__title">Contexto de trabajo</div>
              <div class="pmv-hero-aside__grid">
                <div class="pmv-hero-aside__item">
                  <span>Club</span>
                  <strong><%= activeClubName || 'Sin club asignado' %></strong>
                </div>
                <div class="pmv-hero-aside__item">
                  <span>Equipo por defecto</span>
                  <strong><%= defaultTeamName || 'Sin equipo asignado' %></strong>
                </div>
                <div class="pmv-hero-aside__item">
                  <span>Temporada</span>
                  <strong><%= activeSeason ? activeSeason.name : 'Sin temporada activa' %></strong>
                </div>
                <div class="pmv-hero-aside__item">
                  <span>Club activo</span>
                  <strong><%= dashboard && dashboard.metrics ? dashboard.metrics.activeTeams : 0 %> equipos</strong>
                </div>
              </div>
              <% if (dashboard && dashboard.metrics) { %>
                <div class="pmv-inline-insights">
                  <span class="badge rounded-pill text-bg-light border"><%= dashboard.metrics.totalActivePlayers %> jugadores activos</span>
                  <span class="badge rounded-pill text-bg-light border"><%= dashboard.metrics.reportsInActiveSeason %> informes en temporada</span>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-4">
    <div class="mb-3">
      <h2 class="h4 mb-1">Actividad reciente</h2>
      <p class="text-muted mb-0">Lo último que se ha registrado en el club.</p>
    </div>

    <div class="row g-4">
      <div class="col-12 col-xl-4">
        <div class="card pmv-list-card shadow-sm h-100">
          <div class="card-body">
            <h3 class="h5 mb-3">Últimas evaluaciones</h3>
            <% if (recentActivity.evaluations.length) { %>
              <ul class="list-unstyled mb-0 pmv-activity-list">
                <% recentActivity.evaluations.forEach((item) => { %>
                  <li>
                    <div class="fw-semibold"><a href="/players/<%= item.playerId %>" class="text-decoration-none"><%= item.playerName %></a></div>
                    <div class="small text-muted"><%= item.teamName || '-' %> · <%= item.date ? new Date(item.date).toISOString().slice(0, 10) : '-' %></div>
                    <div class="small mt-1"><a href="/evaluations/<%= item.id %>" class="text-decoration-none">Abrir evaluación</a></div>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="text-muted mb-0">Todavía no hay evaluaciones recientes.</p>
            <% } %>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-4">
        <div class="card pmv-list-card shadow-sm h-100">
          <div class="card-body">
            <h3 class="h5 mb-3">Últimos informes</h3>
            <% if (recentActivity.reports.length) { %>
              <ul class="list-unstyled mb-0 pmv-activity-list">
                <% recentActivity.reports.forEach((item) => { %>
                  <li>
                    <div class="fw-semibold"><a href="/reports/<%= item.id %>" class="text-decoration-none"><%= item.playerName %></a></div>
                    <div class="small text-muted"><%= item.teamName || '-' %> · <%= item.date ? new Date(item.date).toISOString().slice(0, 10) : '-' %></div>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="text-muted mb-0">Todavía no hay informes recientes.</p>
            <% } %>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-4">
        <div class="card pmv-list-card shadow-sm h-100">
          <div class="card-body">
            <h3 class="h5 mb-3">Actividad por equipo</h3>
            <% if (recentActivity.teams.length) { %>
              <ul class="list-unstyled mb-0 pmv-activity-list">
                <% recentActivity.teams.forEach((item) => { %>
                  <li>
                    <div class="fw-semibold"><a href="/teams/<%= item.teamId %>" class="text-decoration-none"><%= item.teamName %></a></div>
                    <div class="small text-muted"><%= item.evaluationsCount %> evaluaciones · <%= item.reportsCount %> informes</div>
                    <div class="small mt-1"><a href="/teams/<%= item.teamId %>" class="text-decoration-none">Abrir equipo</a></div>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="text-muted mb-0">Sin actividad reciente por equipo.</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-4">
    <div class="row g-3">
      <div class="col-12 col-md-6 col-xl-3">
        <div class="card pmv-insight-card shadow-sm h-100 border-0">
          <div class="card-body">
            <div class="small text-uppercase text-muted">Club</div>
            <div class="fw-semibold"><%= activeClubName || 'Sin club asignado' %></div>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <div class="card pmv-insight-card shadow-sm h-100 border-0">
          <div class="card-body">
            <div class="small text-uppercase text-muted">Equipo por defecto</div>
            <div class="fw-semibold"><%= defaultTeamName || 'Sin equipo asignado' %></div>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <div class="card pmv-insight-card shadow-sm h-100 border-0">
          <div class="card-body">
            <div class="small text-uppercase text-muted">Temporada</div>
            <div class="fw-semibold"><%= activeSeason ? activeSeason.name : 'Sin temporada activa' %></div>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <div class="card pmv-insight-card shadow-sm h-100 border-0">
          <div class="card-body">
            <div class="small text-uppercase text-muted">Estado</div>
            <div class="fw-semibold"><%= dashboard && dashboard.metrics ? dashboard.metrics.activeTeams : 0 %> equipos · <%= dashboard && dashboard.metrics ? dashboard.metrics.totalActivePlayers : 0 %> jugadores</div>
          </div>
        </div>
      </div>
    </div>
  </section>
<% } else { %>
  <section class="dashboard-suite mb-4">
    <div class="card dashboard-context-card shadow-sm border-0">
      <div class="card-body p-4 p-lg-5">
        <div class="row g-4 align-items-start">
          <div class="col-12 col-lg-8">
            <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
              <span class="dashboard-kicker">SoccerProcessIQ Suite</span>
              <span class="badge text-bg-light border">Modular Football Club Platform</span>
            </div>
            <h1 class="h3 mb-2">Panel general del club</h1>
            <p class="text-muted mb-4">
              <%= currentUser ? `Visión rápida para ${currentUser.name}.` : 'Visión rápida de la suite.' %>
              Accede al núcleo operativo y a los módulos activos del club desde un solo punto.
            </p>

            <div class="row g-3">
              <div class="col-12 col-md-4">
                <div class="dashboard-context-stat">
                  <div class="small text-uppercase text-muted">Club</div>
                  <div class="fw-semibold mt-1"><%= activeClubName || 'Sin club asignado' %></div>
                </div>
              </div>
              <div class="col-12 col-md-4">
                <div class="dashboard-context-stat">
                  <div class="small text-uppercase text-muted">Equipo por defecto</div>
                  <div class="fw-semibold mt-1"><%= defaultTeamName || 'Sin equipo asignado' %></div>
                </div>
              </div>
              <div class="col-12 col-md-4">
                <div class="dashboard-context-stat">
                  <div class="small text-uppercase text-muted">Temporada activa</div>
                  <div class="fw-semibold mt-1"><%= activeSeason ? activeSeason.name : 'Sin temporada activa' %></div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-4">
            <div class="dashboard-context-panel">
              <div class="small text-uppercase text-muted mb-2">Estado de la suite</div>
              <div class="d-flex align-items-end gap-2 mb-2">
                <div class="display-6 fw-semibold lh-1"><%= activeModuleCount %></div>
                <div class="text-muted mb-1">módulos activos</div>
              </div>
              <div class="small text-muted mb-3">
                SPI Core permanece disponible como base común y los módulos se muestran según la activación del club.
              </div>
              <div class="d-flex flex-wrap gap-2">
                <a href="/account" class="btn btn-sm btn-outline-secondary">Mi cuenta</a>
                <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'superadmin')) { %>
                  <a href="/admin/club" class="btn btn-sm btn-primary">Configurar club</a>
                <% } %>
                <% if (currentUser && currentUser.role === 'superadmin') { %>
                  <a href="/admin/platform" class="btn btn-sm btn-outline-secondary">Plataforma</a>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
      <div>
        <h2 class="h4 mb-1">SPI Core</h2>
        <p class="text-muted mb-0">Núcleo operativo común de SoccerProcessIQ Suite.</p>
      </div>
      <% if (dashboard && dashboard.metrics) { %>
        <div class="d-flex flex-wrap gap-2 dashboard-inline-metrics">
          <span class="badge rounded-pill text-bg-light border"><%= dashboard.metrics.activeTeams %> equipos activos</span>
          <span class="badge rounded-pill text-bg-light border"><%= dashboard.metrics.totalActivePlayers %> jugadores activos</span>
        </div>
      <% } %>
    </div>

    <div class="row g-4">
      <% coreEntries.forEach((entry) => { %>
        <div class="col-12 col-md-6 col-xl-4">
          <a href="<%= entry.href %>" class="text-decoration-none text-reset">
            <div class="card dashboard-entry-card h-100 shadow-sm">
              <div class="card-body">
                <div class="dashboard-entry-eyebrow">SPI Core</div>
                <h3 class="h5 mb-2"><%= entry.title %></h3>
                <p class="text-muted small mb-3"><%= entry.description %></p>
                <div class="small fw-semibold"><%= entry.meta %></div>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
      <div>
        <h2 class="h4 mb-1">Módulos activos</h2>
        <p class="text-muted mb-0">Verticales habilitados para el club dentro de la suite modular.</p>
      </div>
      <span class="badge rounded-pill text-bg-light border"><%= activeModuleCount %> activos</span>
    </div>

    <% if (moduleEntries.length) { %>
      <div class="row g-4">
        <% moduleEntries.forEach((moduleEntry) => { %>
          <div class="col-12 col-lg-6">
            <div class="card dashboard-module-card h-100 shadow-sm">
              <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                  <div>
                    <div class="dashboard-entry-eyebrow">Módulo activo</div>
                    <h3 class="h5 mb-1"><%= moduleEntry.title %></h3>
                    <p class="text-muted small mb-0"><%= moduleEntry.strapline %></p>
                  </div>
                  <span class="badge rounded-pill text-bg-success-subtle border border-success-subtle text-success-emphasis">Activo</span>
                </div>

                <p class="mb-3"><%= moduleEntry.description %></p>

                <div class="d-flex flex-wrap gap-2 mb-3">
                  <% moduleEntry.meta.forEach((metaItem) => { %>
                    <span class="badge rounded-pill text-bg-light border"><%= metaItem %></span>
                  <% }) %>
                </div>

                <div class="mt-auto d-flex flex-wrap gap-2">
                  <% moduleEntry.actions.forEach((action) => { %>
                    <a href="<%= action.href %>" class="btn btn-<%= action.variant %>"><%= action.label %></a>
                  <% }) %>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="card shadow-sm">
        <div class="card-body">
          <h3 class="h6 mb-2">Sin módulos adicionales activos</h3>
          <p class="text-muted mb-0">
            El club mantiene disponible SPI Core como base operativa. Cuando se activen módulos, aparecerán aquí con sus accesos correspondientes.
          </p>
        </div>
      </div>
    <% } %>
  </section>
<% } %>

<% if (showPendingByTeam) { %>
  <section class="mb-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
          <div>
            <div class="dashboard-entry-eyebrow">SPI Scouting Players</div>
            <h2 class="h5 mb-1">Seguimiento operativo de evaluaciones</h2>
            <p class="text-muted mb-0">Equipos con jugadores pendientes de evaluar en la temporada activa.</p>
          </div>
          <a href="/evaluations/compare" class="btn btn-sm btn-outline-secondary">Comparativa</a>
        </div>
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead>
              <tr>
                <th>Equipo</th>
                <th>Jugadores</th>
                <th>Evaluados</th>
                <th>Pendientes</th>
                <th>Cobertura</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% dashboard.pendingByTeam.forEach((teamRow) => { %>
                <tr>
                  <td>
                    <div class="fw-semibold"><%= teamRow.teamName %></div>
                    <div class="small text-muted"><%= teamRow.sectionName %> · <%= teamRow.categoryName %></div>
                  </td>
                  <td><%= teamRow.totalPlayers %></td>
                  <td><%= teamRow.evaluatedPlayers %></td>
                  <td><%= teamRow.pendingPlayers %></td>
                  <td style="min-width: 180px;">
                    <div class="progress" role="progressbar" aria-label="Cobertura de evaluaciones" aria-valuenow="<%= teamRow.completionPercentage %>" aria-valuemin="0" aria-valuemax="100">
                      <div
                        class="progress-bar"
                        style="width: <%= teamRow.completionPercentage %>%"
                      >
                        <%= teamRow.completionPercentage.toFixed(0) %>%
                      </div>
                    </div>
                  </td>
                  <td class="text-end">
                    <a href="/teams/<%= teamRow.teamId %>" class="btn btn-sm btn-outline-secondary">Abrir equipo</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
<% } %>
