<!-- BLOQUE 1 — CONTEXTO -->
<div class="row g-3 mb-4">
  <div class="col-12 col-md-8">
    <div class="card shadow-sm">
      <div class="card-body d-flex flex-column flex-md-row justify-content-between gap-3 align-items-start align-items-md-center">
        <div>
          <h2 class="h5 mb-1">Contexto</h2>
          <div class="small text-muted">Club activo</div>
          <div class="fw-semibold mb-1"><%= activeClubName || 'Sin club asignado' %></div>
          <div class="small text-muted">Equipo por defecto</div>
          <div class="fw-semibold"><%= (currentUser && (currentUser.default_team || currentUser.defaultTeam || currentUser.defaultTeamName)) || '—' %></div>
        </div>
        <div class="text-end">
          <div class="small text-muted">Temporada</div>
          <div class="fw-semibold"><%= activeSeason ? activeSeason.name : 'Sin temporada activa' %></div>
          <div class="mt-2">
            <a href="/account" class="btn btn-sm btn-outline-secondary">Mi cuenta</a>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-4">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h2 class="h6 mb-2">SoccerProcessIQ Suite</h2>
        <div class="small text-muted">Modular Football Club Platform</div>
        <div class="mt-3">
          <% if (dashboard && dashboard.modules) { %>
            <% const activeCount = (dashboard.modules.scoutingPlayersEnabled ? 1 : 0) + (dashboard.modules.scoutingTeamsEnabled ? 1 : 0) + (activeModuleKeys.includes('planning') ? 1 : 0); %>
            <div class="fw-semibold"><%= activeCount %> módulos activos</div>
          <% } else { %>
            <div class="fw-semibold">Sin módulos configurados</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- BLOQUE 2 — SPI CORE -->
<section class="mb-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <div>
      <h2 class="h5 mb-0">SPI Core</h2>
      <p class="text-muted mb-0">Operaciones y configuración básica del club</p>
    </div>
  </div>

  <div class="row g-4 mb-3">
    <div class="col-6 col-md-3">
      <a href="/teams" class="text-decoration-none text-reset">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <img src="/img/list.svg" class="mb-2" alt="Equipos" style="height:36px;" />
            <div class="fw-semibold">Equipos</div>
            <div class="small text-muted">Accede al listado de equipos</div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-6 col-md-3">
      <a href="/admin/players" class="text-decoration-none text-reset">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <img src="/img/players.svg" class="mb-2" alt="Jugadores" style="height:36px;" />
            <div class="fw-semibold">Jugadores</div>
            <div class="small text-muted">Perfiles y gestión de plantilla</div>
            <% if (dashboard && dashboard.metrics) { %>
              <div class="mt-2 display-6 fw-semibold"><%= dashboard.metrics.totalActivePlayers %></div>
            <% } %>
          </div>
        </div>
      </a>
    </div>
    <div class="col-6 col-md-3">
      <a href="/admin/users" class="text-decoration-none text-reset">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <img src="/img/users.svg" class="mb-2" alt="Usuarios" style="height:36px;" />
            <div class="fw-semibold">Usuarios</div>
            <div class="small text-muted">Roles y accesos</div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-6 col-md-3">
      <a href="/admin/club" class="text-decoration-none text-reset">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <img src="/img/list.svg" class="mb-2" alt="Configuración" style="height:36px;" />
            <div class="fw-semibold">Configuración</div>
            <div class="small text-muted">Ajustes del club</div>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- BLOQUE 3 — MÓDULOS ACTIVOS -->
<section class="mb-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <div>
      <h2 class="h5 mb-0">SPI Modules</h2>
      <p class="text-muted mb-0">Accesos rápidos a los módulos habilitados para el club</p>
    </div>
  </div>

  <div class="row g-4">
    <% /* SPI Scouting Players */ %>
    <% if (activeModuleKeys.includes('scouting_players')) { %>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column justify-content-between">
            <div>
              <h3 class="h6">SPI Scouting Players</h3>
              <p class="small text-muted">Informes individuales, valoraciones y seguimiento de jugadores</p>
            </div>
            <div class="mt-3 d-flex flex-wrap gap-2">
              <a href="/reports/new" class="btn btn-primary">Nuevo informe</a>
              <a href="/reports" class="btn btn-outline-secondary">Ver informes</a>
              <a href="/assessments" class="btn btn-outline-secondary">Valoraciones</a>
            </div>
          </div>
        </div>
      </div>
    <% } %>

    <% /* SPI Planning */ %>
    <% if (activeModuleKeys.includes('planning')) { %>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column justify-content-between">
            <div>
              <h3 class="h6">SPI Planning</h3>
              <p class="small text-muted">Temporadas, microciclos y sesiones</p>
            </div>
            <div class="mt-3 d-flex flex-wrap gap-2">
              <a href="/seasons" class="btn btn-primary">Temporadas</a>
              <a href="/planning" class="btn btn-outline-secondary">Planning</a>
            </div>
          </div>
        </div>
      </div>
    <% } %>

    <% /* SPI Scouting Teams */ %>
    <% if (activeModuleKeys.includes('scouting_teams')) { %>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column justify-content-between">
            <div>
              <h3 class="h6">SPI Scouting Teams</h3>
              <p class="small text-muted">Informes de rivales y análisis táctico</p>
              <% if (dashboard && dashboard.modules) { %>
                <div class="small text-muted mt-1"><%= dashboard.modules.scoutingTeamsReportCount %> informes registrados</div>
              <% } %>
            </div>
            <div class="mt-3 d-flex flex-wrap gap-2">
              <a href="/scouting-teams/new" class="btn btn-primary">Nuevo informe rival</a>
              <a href="/scouting-teams" class="btn btn-outline-secondary">Informes de rivales</a>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</section>

<!-- Sección: Pendientes por equipo (si hay datos de scouting players) -->
<% if (dashboard && dashboard.modules && dashboard.modules.scoutingPlayersEnabled && dashboard.pendingByTeam && dashboard.pendingByTeam.length) { %>
  <section class="mb-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h2 class="h5 mb-0">Jugadores sin evaluación por equipo</h2>
          <a href="/evaluations/compare" class="btn btn-sm btn-outline-secondary">Comparativa</a>
        </div>
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead>
              <tr>
                <th>Equipo</th>
                <th>Categoria</th>
                <th>Seccion</th>
                <th>Total jugadores</th>
                <th>Evaluados</th>
                <th>Pendientes</th>
                <th>Avance</th>
              </tr>
            </thead>
            <tbody>
              <% dashboard.pendingByTeam.forEach((team) => { %>
                <tr>
                  <td class="fw-semibold"><%= team.teamName %></td>
                  <td><%= team.categoryName %></td>
                  <td><%= team.sectionName %></td>
                  <td><%= team.totalPlayers %></td>
                  <td><%= team.evaluatedPlayers %></td>
                  <td><%= team.pendingPlayers %></td>
                  <td style="min-width: 220px;">
                    <div class="d-flex align-items-center gap-3">
                      <div class="progress flex-grow-1" role="progressbar" aria-valuenow="<%= team.completionPercentage %>" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar" style="width: <%= team.completionPercentage %>%"></div>
                      </div>
                      <span class="small fw-semibold"><%= team.completionPercentage.toFixed(0) %>%</span>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
<% } %>

<!-- ADMIN -->
<% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'superadmin')) { %>
  <section>
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
      <div>
        <h2 class="h5 mb-1">Administración</h2>
        <p class="text-muted mb-0">Configuración interna, estructura del club y gestión de accesos.</p>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-6 col-xl-3">
        <a href="/admin/club" class="text-decoration-none text-reset">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title">Administración de equipos</h5>
              <p class="card-text">Gestionar la estructura deportiva y la configuración del club.</p>
            </div>
          </div>
        </a>
      </div>
      <div class="col-md-6 col-xl-3">
        <a href="/admin/users" class="text-decoration-none text-reset">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title">Gestión de usuarios</h5>
              <p class="card-text">Administrar accesos y roles del club.</p>
            </div>
          </div>
        </a>
      </div>
      <% if (currentUser && currentUser.role === 'superadmin') { %>
        <div class="col-md-6 col-xl-3">
          <a href="/clubs" class="text-decoration-none text-reset">
            <div class="card h-100 shadow-sm">
              <div class="card-body">
                <h5 class="card-title">Clubes</h5>
                <p class="card-text">Alta, edición y mantenimiento administrativo de clubes.</p>
              </div>
            </div>
          </a>
        </div>
      <% } %>
    </div>
  </section>
<% } %>
