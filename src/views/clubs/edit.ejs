<h1 class="mb-4">Editar club</h1>

<form method="POST" action="/admin/clubs/<%= club.id %>/edit" class="col-md-5">
  <div class="mb-3">
    <label for="name" class="form-label">Nombre del club</label>
    <input
      type="text"
      class="form-control"
      id="name"
      name="name"
      value="<%= club.name %>"
      required
    />
  </div>

  <div class="mb-3">
    <label class="form-label">Código de registro</label>
    <input
      type="text"
      class="form-control"
      value="<%= club.code %>"
      disabled
    />
    <div class="form-text">
      El código de registro no puede modificarse una vez creado.
    </div>
  </div>

  <button type="submit" class="btn btn-sr-primary">Guardar cambios</button>
  <a href="/admin/clubs" class="btn btn-link">Volver</a>
</form>
