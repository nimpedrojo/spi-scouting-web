<div class="card shadow-sm">
  <div class="card-body">
    <% const selectedTeamId = formValues.team_id || formData.teamId || ''; %>
    <% const selectedPlayerId = formValues.player_id || formData.playerId || ''; %>
    <% const allPlayers = formData.allPlayers || formData.players || []; %>
    <% const selectedTeam = (formData.teams || []).find((team) => String(team.id) === String(selectedTeamId)); %>
    <% const selectedPlayer = allPlayers.find((player) => String(player.id) === String(selectedPlayerId)); %>
    <% if ((productModeInfo && productModeInfo.isPmvPlayerTracking) && (selectedTeam || selectedPlayer)) { %>
      <div class="border rounded-3 bg-light p-3 mb-4">
        <div class="small text-uppercase text-muted mb-1">Flujo PMV</div>
        <div class="fw-semibold mb-1">
          <%= selectedPlayer ? `${selectedPlayer.first_name} ${selectedPlayer.last_name}` : 'Nueva evaluación' %>
        </div>
        <div class="text-muted small">
          <%= selectedTeam ? `Equipo: ${selectedTeam.name}. ` : '' %>
          Registra una evaluación y vuelve después a la ficha del jugador para revisar su histórico.
        </div>
      </div>
    <% } %>
    <% if (errors && errors.length) { %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% errors.forEach((error) => { %>
            <li><%= error %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form method="POST" action="/evaluations" class="row g-3">
      <div class="col-md-4">
        <label for="template_id" class="form-label">Plantilla</label>
        <select id="template_id" name="template_id" class="form-select">
          <% if (formData.availableTemplates && formData.availableTemplates.length) { %>
            <% formData.availableTemplates.forEach((templateOption) => { %>
              <option
                value="<%= templateOption.id %>"
                <%= String(formValues.template_id || formData.templateId || '') === String(templateOption.id) ? 'selected' : '' %>
              >
                <%= templateOption.name %>
              </option>
            <% }) %>
          <% } else { %>
            <option value="<%= formData.templateId || 'fallback-default' %>">Plantilla por defecto</option>
          <% } %>
        </select>
      </div>
      <div class="col-md-3">
        <label for="season_id" class="form-label">Temporada</label>
        <select id="season_id" name="season_id" class="form-select" required>
          <% formData.seasons.forEach((season) => { %>
            <option
              value="<%= season.id %>"
              <%= String(formValues.season_id || (formData.activeSeason ? formData.activeSeason.id : '')) === String(season.id) ? 'selected' : '' %>
            >
              <%= season.name %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <label for="team_id" class="form-label">Equipo</label>
        <select id="team_id" name="team_id" class="form-select" required>
          <option value="">Selecciona equipo</option>
          <% formData.teams.forEach((team) => { %>
            <option value="<%= team.id %>" <%= String(selectedTeamId) === String(team.id) ? 'selected' : '' %>><%= team.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label for="player_id" class="form-label">Jugador</label>
        <select id="player_id" name="player_id" class="form-select" required>
          <option value="">Selecciona jugador</option>
          <% formData.players.forEach((player) => { %>
            <option
              value="<%= player.id %>"
              data-team-id="<%= player.current_team_id || '' %>"
              <%= String(selectedPlayerId) === String(player.id) ? 'selected' : '' %>
            >
              <%= player.first_name %> <%= player.last_name %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label for="evaluation_date" class="form-label">Fecha</label>
        <input type="date" id="evaluation_date" name="evaluation_date" class="form-control" required value="<%= formValues.evaluation_date || new Date().toISOString().slice(0, 10) %>" />
      </div>
      <div class="col-md-6">
        <label for="title" class="form-label">Titulo</label>
        <input type="text" id="title" name="title" class="form-control" value="<%= formValues.title || '' %>" placeholder="Ej. Seguimiento mensual" />
      </div>
      <div class="col-12">
        <label for="notes" class="form-label">Notas</label>
        <textarea id="notes" name="notes" class="form-control" rows="4"><%= formValues.notes || '' %></textarea>
      </div>

      <% formData.template.forEach((area) => { %>
        <div class="col-12">
          <div class="card border-0 bg-light">
            <div class="card-body">
              <h2 class="h5 mb-3"><%= area.label %></h2>
              <div class="row g-3">
                <% area.metrics.forEach((metric) => { %>
                  <div class="col-md-3">
                    <label for="score_<%= area.key %>_<%= metric.key %>" class="form-label"><%= metric.label %></label>
                    <input
                      type="number"
                      min="0"
                      max="10"
                      step="0.1"
                      class="form-control"
                      id="score_<%= area.key %>_<%= metric.key %>"
                      name="score_<%= area.key %>_<%= metric.key %>"
                      <%= metric.isRequired ? 'required' : '' %>
                      value="<%= formValues['score_' + area.key + '_' + metric.key] || '' %>"
                    />
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>

      <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Guardar evaluacion</button>
        <a href="<%= (flowContext && flowContext.returnToPlayerHref) || (flowContext && flowContext.returnToTeamHref) || '/evaluations' %>" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    var teamSelect = document.getElementById('team_id');
    var playerSelect = document.getElementById('player_id');
    if (!teamSelect || !playerSelect) return;

    var allPlayers = <%- JSON.stringify(allPlayers.map((player) => ({
      id: player.id,
      first_name: player.first_name,
      last_name: player.last_name,
      current_team_id: player.current_team_id || '',
    }))) %>;
    var selectedPlayerId = <%- JSON.stringify(String(selectedPlayerId || '')) %>;

    function buildOption(player, isSelected) {
      var option = document.createElement('option');
      option.value = String(player.id);
      option.textContent = [player.first_name, player.last_name].filter(Boolean).join(' ');
      option.dataset.teamId = player.current_team_id || '';
      if (isSelected) {
        option.selected = true;
      }
      return option;
    }

    function syncPlayers() {
      var selectedTeamId = String(teamSelect.value || '');
      var currentPlayerId = String(playerSelect.value || selectedPlayerId || '');
      var filteredPlayers = selectedTeamId
        ? allPlayers.filter(function (player) {
          return String(player.current_team_id || '') === selectedTeamId;
        })
        : allPlayers;

      playerSelect.innerHTML = '';
      playerSelect.appendChild(buildOption({
        id: '',
        first_name: 'Selecciona',
        last_name: 'jugador',
        current_team_id: '',
      }, false));
      playerSelect.options[0].value = '';

      var hasSelectedPlayer = false;
      filteredPlayers.forEach(function (player) {
        var isSelected = currentPlayerId && String(player.id) === currentPlayerId;
        if (isSelected) {
          hasSelectedPlayer = true;
        }
        playerSelect.appendChild(buildOption(player, isSelected));
      });

      if (!hasSelectedPlayer) {
        playerSelect.value = '';
      }
    }

    teamSelect.addEventListener('change', syncPlayers);
    syncPlayers();
  })();
</script>
