<h1 class="mb-4">Gestión de usuarios</h1>

<form
  method="POST"
  action="/admin/users/bulk-delete"
  onsubmit="return confirm('¿Seguro que quieres borrar los usuarios seleccionados?');"
>
  <div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead>
      <tr>
        <th>
          <input type="checkbox" id="selectAllUsers" />
        </th>
        <th>ID</th>
        <th>Nombre</th>
        <th>Email</th>
        <th>Rol</th>
        <th>Club por defecto</th>
        <th>Equipo por defecto</th>
        <th>Creado</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(function (u) { %>
      <tr>
        <td>
          <% if (!currentUser || currentUser.id !== u.id) { %>
          <input
            type="checkbox"
            class="user-select"
            name="userIds"
            value="<%= u.id %>"
          />
          <% } %>
        </td>
        <td><%= u.id %></td>
        <td><%= u.name %></td>
        <td><%= u.email %></td>
        <td>
          <form
            method="POST"
            action="/admin/users/<%= u.id %>/role"
            class="d-flex align-items-center gap-2"
          >
            <select
              name="role"
              class="form-select form-select-sm"
              <%= (currentUser && currentUser.id === u.id) ? 'disabled' : '' %>
            >
              <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>
                Usuario
              </option>
              <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>
                Admin
              </option>
            </select>
            <% if (!currentUser || currentUser.id !== u.id) { %>
            <button type="submit" class="btn btn-sm btn-primary">
              Guardar
            </button>
            <% } %>
          </form>
        </td>
        <td><%= u.default_club || '' %></td>
        <td><%= u.default_team || '' %></td>
        <td>
          <%= u.created_at ? new Date(u.created_at).toISOString().slice(0, 10) : '' %>
        </td>
        <td class="text-nowrap d-flex gap-2">
          <a
            href="/admin/users/<%= u.id %>/edit"
            class="btn btn-sm btn-outline-secondary"
          >
            Editar
          </a>
          <% if (!currentUser || currentUser.id !== u.id) { %>
          <form
            method="POST"
            action="/admin/users/<%= u.id %>/delete"
            onsubmit="return confirm('¿Seguro que quieres borrar este usuario?');"
          >
            <button type="submit" class="btn btn-sm btn-outline-danger">
              Borrar
            </button>
          </form>
          <% } else { %>
          <span class="text-muted align-self-center">Tu usuario</span>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

  <div class="mt-3">
    <button type="submit" class="btn btn-danger btn-sm">
      Borrar seleccionados
    </button>
  </div>
</form>

<script>
  (function () {
    var selectAll = document.getElementById('selectAllUsers');
    if (!selectAll) return;
    selectAll.addEventListener('change', function () {
      var checks = document.querySelectorAll('input.user-select');
      checks.forEach(function (c) {
        c.checked = selectAll.checked;
      });
    });
  })();
</script>
