<%
  const isSuperAdminView = currentUser && currentUser.role === 'superadmin';

  function formatDateTime(value) {
    if (!value) {
      return 'Nunca';
    }

    return new Intl.DateTimeFormat('es-ES', {
      dateStyle: 'short',
      timeStyle: 'short',
      timeZone: 'Europe/Madrid',
    }).format(new Date(value));
  }
%>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
  <h1 class="mb-0">Gestión de usuarios</h1>
  <a href="/admin/users/new" class="btn btn-primary">Nuevo usuario</a>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead>
      <tr>
        <th>
          <input type="checkbox" id="selectAllUsers" />
        </th>
        <th>ID</th>
        <th>Nombre</th>
        <th>Email</th>
        <th>Rol</th>
        <th>Club asignado</th>
        <th>Club por defecto</th>
        <th>Equipo por defecto</th>
        <% if (isSuperAdminView) { %>
        <th>Último login</th>
        <% } %>
        <th>Creado</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(function (u) { %>
      <tr>
        <td>
          <% if (!currentUser || currentUser.id !== u.id) { %>
          <input
            type="checkbox"
            class="user-select"
            name="userIds"
            value="<%= u.id %>"
          />
          <% } %>
        </td>
        <td><%= u.id %></td>
        <td><%= u.name %></td>
        <td><%= u.email %></td>
        <td>
          <div class="d-flex align-items-center gap-2">
            <select
              name="role"
              class="form-select form-select-sm"
              form="role-form-<%= u.id %>"
              <%= (currentUser && currentUser.id === u.id) ? 'disabled' : '' %>
            >
              <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>
                Usuario
              </option>
              <option
                value="admin"
                <%= u.role === 'admin' ? 'selected' : '' %>
                <%= (!currentUser || currentUser.role !== 'superadmin') ? 'disabled' : '' %>
              >
                Admin
              </option>
              <option
                value="superadmin"
                <%= u.role === 'superadmin' ? 'selected' : '' %>
                <%= (!currentUser || currentUser.role !== 'superadmin') ? 'disabled' : '' %>
              >
                Superadmin
              </option>
            </select>
            <% if (!currentUser || currentUser.id !== u.id) { %>
            <form
              id="role-form-<%= u.id %>"
              method="POST"
              action="/admin/users/<%= u.id %>/role"
            >
            </form>
            <button
              type="submit"
              class="btn btn-sm btn-primary"
              form="role-form-<%= u.id %>"
            >
              Guardar
            </button>
            <% } %>
          </div>
        </td>
        <td><%= u.club_name || u.default_club || '' %></td>
        <td><%= u.default_club || '' %></td>
        <td><%= u.default_team_name || u.default_team || '' %></td>
        <% if (isSuperAdminView) { %>
        <td><%= formatDateTime(u.last_login_at) %></td>
        <% } %>
        <td>
          <%= u.created_at ? new Date(u.created_at).toISOString().slice(0, 10) : '' %>
        </td>
        <td class="text-nowrap d-flex gap-2">
          <a
            href="/admin/users/<%= u.id %>/edit"
            class="btn btn-sm btn-outline-secondary"
          >
            Editar
          </a>
          <% if (!currentUser || currentUser.id !== u.id) { %>
          <form
            method="POST"
            action="/admin/users/<%= u.id %>/delete"
            onsubmit="return confirm('¿Seguro que quieres borrar este usuario?');"
          >
            <button type="submit" class="btn btn-sm btn-outline-danger">
              Borrar
            </button>
          </form>
          <% } else { %>
          <span class="text-muted align-self-center">Tu usuario</span>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="mt-3">
  <form
    id="bulkDeleteForm"
    method="POST"
    action="/admin/users/bulk-delete"
  >
    <button type="submit" class="btn btn-danger btn-sm">
      Borrar seleccionados
    </button>
  </form>
</div>

<script>
  (function () {
    var selectAll = document.getElementById('selectAllUsers');
    if (!selectAll) return;
    selectAll.addEventListener('change', function () {
      var checks = document.querySelectorAll('input.user-select');
      checks.forEach(function (c) {
        c.checked = selectAll.checked;
      });
    });

    var bulkForm = document.getElementById('bulkDeleteForm');
    if (bulkForm) {
      bulkForm.addEventListener('submit', function (e) {
        // Limpiar inputs ocultos previos
        var oldHidden = bulkForm.querySelectorAll('input[type="hidden"][name="userIds"]');
        oldHidden.forEach(function (el) {
          el.remove();
        });

        var checks = document.querySelectorAll('input.user-select:checked');
        if (!checks.length) {
          e.preventDefault();
          alert('No has seleccionado ningún usuario para borrar.');
          return;
        }

        checks.forEach(function (c) {
          var hidden = document.createElement('input');
          hidden.type = 'hidden';
          hidden.name = 'userIds';
          hidden.value = c.value;
          bulkForm.appendChild(hidden);
        });

        if (!confirm('¿Seguro que quieres borrar los usuarios seleccionados?')) {
          e.preventDefault();
        }
      });
    }
  })();
</script>
