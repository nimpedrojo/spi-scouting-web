<%
  const isPmvMode = productModeInfo && productModeInfo.isPmvPlayerTracking;
  const contextualPlayerName = flowContext && flowContext.selectedPlayer
    ? `${flowContext.selectedPlayer.first_name} ${flowContext.selectedPlayer.last_name}`.trim()
    : '';
  const contextualTeamName = (formData && formData.team) || '';
  const cancelHref = (flowContext && flowContext.returnToPlayerHref)
    || (flowContext && flowContext.returnToTeamHref)
    || '/reports';
%>

<div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
  <div>
    <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
      <span class="dashboard-kicker"><%= isPmvMode ? 'SPI Player Tracking' : 'SoccerProcessIQ Suite' %></span>
      <% if (isPmvMode) { %>
        <span class="badge text-bg-light border">Informe de jugador</span>
      <% } %>
    </div>
    <h1 class="mb-1">Nuevo informe</h1>
    <p class="text-muted mb-0">
      <% if (contextualPlayerName) { %>
        Estás creando un informe para <strong><%= contextualPlayerName %></strong><% if (contextualTeamName) { %> · <%= contextualTeamName %><% } %>.
      <% } else { %>
        Registra una observación individual y vincúlala al jugador para mantener su histórico actualizado.
      <% } %>
    </p>
  </div>
  <a href="<%= cancelHref %>" class="btn btn-outline-secondary">Cancelar</a>
</div>

<form method="POST" action="/reports/new">
  <input type="hidden" name="player_id" value="<%= (formData && formData.player_id) || '' %>" />
  <input type="hidden" name="team_id" value="<%= (formData && formData.team_id) || '' %>" />
  <div class="row mb-3">
    <div class="col-md-6 mb-3">
      <label class="form-label">Seleccionar jugador (opcional)</label>
      <select id="playerSelect" class="form-select">
        <option value="">-- Selecciona un jugador --</option>
        <% if (typeof players !== 'undefined' && players && players.length) { %>
          <% players.forEach(function (p) { %>
            <option
              value="<%= p.id %>"
              <%= String((formData && formData.player_id) || '') === String(p.id) ? 'selected' : '' %>
              data-first-name="<%= p.first_name %>"
              data-last-name="<%= p.last_name %>"
              data-team="<%= p.relational_team_name || '' %>"
              data-year="<%= p.birth_year || '' %>"
              data-laterality="<%= p.laterality || '' %>"
            >
              <%= p.first_name %> <%= p.last_name %> (<%= p.relational_team_name || 'Sin equipo' %>)
            </option>
          <% }) %>
        <% } %>
      </select>
      <small class="text-muted">
        Al seleccionar un jugador se rellenarán automáticamente nombre, apellidos, equipo, año y lateralidad.
      </small>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-4">
      <label class="form-label">Nombre <span class="text-danger">*</span></label>
      <input
        type="text"
        name="player_name"
        class="form-control <%= validationErrors.player_name ? 'is-invalid' : '' %>"
        value="<%= (formData && formData.player_name) || '' %>"
        required
        aria-required="true"
      />
      <% if (validationErrors.player_name) { %>
      <div class="invalid-feedback">El nombre es obligatorio.</div>
      <% } %>
    </div>
    <div class="col-md-4">
      <label class="form-label">Apellidos <span class="text-danger">*</span></label>
      <input
        type="text"
        name="player_surname"
        class="form-control <%= validationErrors.player_surname ? 'is-invalid' : '' %>"
        value="<%= (formData && formData.player_surname) || '' %>"
        required
        aria-required="true"
      />
      <% if (validationErrors.player_surname) { %>
      <div class="invalid-feedback">Los apellidos son obligatorios.</div>
      <% } %>
    </div>
    <div class="col-md-2">
      <label class="form-label">Año</label>
      <input
        type="number"
        name="year"
        class="form-control"
        value="<%= (formData && formData.year) || '' %>"
      />
    </div>
    <div class="col-md-2">
      <label class="form-label">Lateralidad</label>
      <input
        type="text"
        name="laterality"
        class="form-control"
        value="<%= (formData && formData.laterality) || '' %>"
      />
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-6">
      <div class="row mb-3">
        <div class="col-12">
          <label class="form-label">Club</label>
          <input
            type="text"
            name="club"
            class="form-control"
            value="<%= (formData && formData.club) || '' %>"
          />
        </div>
      </div>
      <div class="row mb-3">
        <div class="col-12">
          <label class="form-label">Equipo</label>
          <input
            type="text"
            name="team"
            class="form-control"
            value="<%= (formData && formData.team) || '' %>"
          />
        </div>
      </div>
      <div class="row mb-3">
        <div class="col-12">
          <label class="form-label">Contacto</label>
          <input
            type="text"
            name="contact"
            class="form-control"
            value="<%= (formData && formData.contact) || '' %>"
          />
        </div>
      </div>
      <div class="row mb-2">
        <div class="col-md-6">
          <label class="form-label">Posición 1</label>
          <input
            type="text"
            name="pos1"
            class="form-control"
            value="<%= (formData && formData.pos1) || '' %>"
          />
        </div>
        <div class="col-md-6">
          <label class="form-label">Posición 2</label>
          <input
            type="text"
            name="pos2"
            class="form-control"
            value="<%= (formData && formData.pos2) || '' %>"
          />
        </div>
      </div>
      <div class="row mb-2">
        <div class="col-md-6">
          <label class="form-label">Posición 3</label>
          <input
            type="text"
            name="pos3"
            class="form-control"
            value="<%= (formData && formData.pos3) || '' %>"
          />
        </div>
        <div class="col-md-6">
          <label class="form-label">Posición 4</label>
          <input
            type="text"
            name="pos4"
            class="form-control"
            value="<%= (formData && formData.pos4) || '' %>"
          />
        </div>
      </div>
      <small class="text-muted"
        >Usa los códigos de la leyenda (POR, LD, LI, DEF, MC, ID, II, MP, ED,
        EI, DEL).</small
      >
    </div>
    <div class="col-md-6 d-flex align-items-center justify-content-center">
      <div class="report-pitch-panel mt-2">
        <div class="team-detail-panel__heading mb-3">Campograma</div>
        <div class="report-pitch">
          <div class="report-pitch__field">
            <svg class="report-pitch__svg" viewBox="0 0 320 440" aria-hidden="true">
              <defs>
                <linearGradient id="reportPitchGrass" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" stop-color="#1d7a3f" />
                  <stop offset="100%" stop-color="#166236" />
                </linearGradient>
              </defs>
              <rect x="0" y="0" width="320" height="440" rx="16" fill="url(#reportPitchGrass)" />
              <rect x="14" y="14" width="292" height="412" rx="10" fill="none" stroke="rgba(255,255,255,0.92)" stroke-width="3" />
              <line x1="14" y1="220" x2="306" y2="220" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <circle cx="160" cy="220" r="34" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <circle cx="160" cy="220" r="2.5" fill="rgba(255,255,255,0.92)" />
              <rect x="72" y="14" width="176" height="74" rx="2" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <rect x="112" y="14" width="96" height="28" rx="2" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <circle cx="160" cy="88" r="2.5" fill="rgba(255,255,255,0.92)" />
              <path d="M128 88a32 32 0 0 0 64 0" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <rect x="72" y="352" width="176" height="74" rx="2" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <rect x="112" y="398" width="96" height="28" rx="2" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <circle cx="160" cy="352" r="2.5" fill="rgba(255,255,255,0.92)" />
              <path d="M128 352a32 32 0 0 1 64 0" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
            </svg>
            <div class="report-pitch__marker pos-del" data-position-code="DEL">DEL</div>
            <div class="report-pitch__marker pos-ei" data-position-code="EI">EI</div>
            <div class="report-pitch__marker pos-mp" data-position-code="MP">MP</div>
            <div class="report-pitch__marker pos-ed" data-position-code="ED">ED</div>
            <div class="report-pitch__marker pos-ii" data-position-code="II">II</div>
            <div class="report-pitch__marker pos-mc" data-position-code="MC">MC</div>
            <div class="report-pitch__marker pos-id" data-position-code="ID">ID</div>
            <div class="report-pitch__marker pos-li" data-position-code="LI">LI</div>
            <div class="report-pitch__marker pos-central" data-position-code="DEF">DEF</div>
            <div class="report-pitch__marker pos-ld" data-position-code="LD">LD</div>
            <div class="report-pitch__marker pos-por" data-position-code="POR">POR</div>
          </div>
        </div>
        <div class="report-pitch__legend">
          <span class="report-pitch__legend-item is-primary">Posición principal</span>
          <span class="report-pitch__legend-item is-secondary">Secundarias</span>
        </div>
      </div>
    </div>
  </div>

