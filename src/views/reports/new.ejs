      <div class="pitch-container mt-2">
        <div class="pitch">
          <div
            class="pitch-position pos-por"
            data-position-code="POR"
          >
            POR
          </div>
          <div
            class="pitch-position pos-central"
            data-position-code="DEF"
          >
            DEF
          </div>
          <div class="pitch-position pos-ld" data-position-code="LD">LD</div>
          <div class="pitch-position pos-li" data-position-code="LI">LI</div>
          <div class="pitch-position pos-mc" data-position-code="MC">MC</div>
