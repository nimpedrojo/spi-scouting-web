  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var select = document.getElementById('playerSelect');
      if (!select) return;
      var hiddenPlayerId = document.querySelector('input[name="player_id"]');
      var hiddenTeamId = document.querySelector('input[name="team_id"]');

      function applySelectedPlayer() {
        var opt = select.options[select.selectedIndex];
        if (!opt || !opt.value) return;

        var firstName = opt.getAttribute('data-first-name') || '';
        var lastName = opt.getAttribute('data-last-name') || '';
        var team = opt.getAttribute('data-team') || '';
        var year = opt.getAttribute('data-year') || '';
        var laterality = opt.getAttribute('data-laterality') || '';

        var nameInput = document.querySelector('input[name=\"player_name\"]');
        var surnameInput = document.querySelector('input[name=\"player_surname\"]');
        var teamInput = document.querySelector('input[name=\"team\"]');
        var yearInput = document.querySelector('input[name=\"year\"]');
        var lateralityInput = document.querySelector('input[name=\"laterality\"]');

        if (nameInput) nameInput.value = firstName;
        if (surnameInput) surnameInput.value = lastName;
        if (teamInput) teamInput.value = team;
        if (yearInput) {
          yearInput.value = year;
          // forzar actualización de opciones de recomendación ligadas al año
          const evt = new Event('input', { bubbles: true });
          yearInput.dispatchEvent(evt);
        }
        if (lateralityInput) lateralityInput.value = laterality;
        if (hiddenPlayerId) hiddenPlayerId.value = opt.value;
      }

      select.addEventListener('change', applySelectedPlayer);

      if (select.value) {
        applySelectedPlayer();
      } else if (hiddenTeamId && !hiddenTeamId.value) {
        hiddenTeamId.value = '<%= (flowContext && flowContext.requestedTeamId) || '' %>';
      }
    });
  </script>

  <div class="row mb-3">
    <div class="col-md-3">
      <label class="form-label">Valoración global</label>
      <input
        type="number"
        step="0.01"
        readonly
        name="overall_rating"
        class="form-control"
      />
    </div>
    <div class="col-md-3">
      <label class="form-label">Recomendación</label>
      <select
        name="recommendation"
        class="form-select"
        id="recommendation"
        data-current-value="<%= (formData && formData.recommendation) || '' %>"
      >
        <option value="">Selecciona recomendación</option>
      </select>
    </div>
    <div class="col-md-3">
      <label class="form-label">Fiabilidad info</label>
      <input
        type="number"
        step="0.01"
        name="info_reliability"
        class="form-control"
        value="<%= (formData && formData.info_reliability) || '' %>"
      />
    </div>
  </div>

  <div class="mb-3">
    <label class="form-label">Comentarios</label>
    <textarea
      name="comments"
      rows="4"
      class="form-control"
      placeholder="Comentarios del informe"
    ><%= (formData && formData.comments) || '' %></textarea>
  </div>

  <div class="d-flex gap-2 flex-wrap">
    <button type="submit" class="btn btn-success">Guardar informe</button>
    <a href="<%= cancelHref %>" class="btn btn-outline-secondary">Cancelar</a>
  </div>
</form>

<script>
  (function () {
    function toNumber(value) {
      if (value === null || value === undefined || value === '') return null;
      const n = Number(value);
      return Number.isNaN(n) ? null : n;
    }

    function average(inputs) {
      const values = inputs
        .map((el) => toNumber(el.value))
        .filter((v) => v !== null && !Number.isNaN(v));
      if (!values.length) return '';
      const sum = values.reduce((a, b) => a + b, 0);
      return (sum / values.length).toFixed(2);
    }

    function setupGroup(fieldNames, totalName) {
      const inputs = fieldNames
        .map((name) => document.querySelector(`input[name="${name}"]`))
        .filter(Boolean);
      const totalInput = document.querySelector(`input[name="${totalName}"]`);
      if (!inputs.length || !totalInput) return;

      function recalc() {
        totalInput.value = average(inputs);
        const event = new Event('input', { bubbles: true });
        totalInput.dispatchEvent(event);
      }

      inputs.forEach((input) => {
        input.addEventListener('input', recalc);
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      setupGroup(
        [
          'tech_cobertura_balon',
          'tech_conduccion',
          'tech_control',
          'tech_regate',
          'tech_disparo',
          'tech_pase',
          'tech_remate_cabeza',
          'tech_anticipacion',
        ],
        'tech_total',
      );
      setupGroup(
        [
          'tact_transicion_ataque_defensa',
          'tact_movimientos_sin_balon',
          'tact_ayudas_defensivas',
          'tact_ayudas_ofensivas',
          'tact_desmarques',
          'tact_marcajes',
        ],
        'tact_total',
      );
      setupGroup(
        [
          'phys_sacrificio',
          'phys_velocidad_punta',
          'phys_velocidad_reaccion',
          'phys_fuerza',
          'phys_potencia',
          'phys_resistencia',
          'phys_coordinacion',
        ],
        'phys_total',
      );
      setupGroup(
        [
          'psych_concentracion',
          'psych_control_emocional',
          'psych_reaccion_errores_arbitrales',
        ],
        'psych_total',
      );
      setupGroup(
        [
          'pers_liderazgo',
          'pers_disciplina',
          'pers_reaccion_correcciones_companero',
          'pers_reaccion_correcciones_tecnico',
        ],
        'pers_total',
      );

      // Recomendación según año de nacimiento (configurable por club)
      const recommendationByYear = <%- JSON.stringify(recommendationConfig || {}) %>;

      function updateRecommendationOptions() {
        const yearInput = document.querySelector('input[name="year"]');
        const select = document.getElementById('recommendation');
        if (!yearInput || !select) return;

        const year = parseInt(yearInput.value, 10);
        const options = recommendationByYear[year] || [];
        const currentValue = select.dataset.currentValue || '';

        // reset opciones
        select.innerHTML =
          '<option value="">' + 'Selecciona recomendación' + '</option>';

        options.forEach((opt) => {
          const option = document.createElement('option');
          option.value = opt;
          option.textContent = opt;
          if (opt === currentValue) {
            option.selected = true;
          }
          select.appendChild(option);
        });

        select.disabled = options.length === 0;
      }

      const yearEl = document.querySelector('input[name="year"]');
      if (yearEl) {
        yearEl.addEventListener('input', updateRecommendationOptions);
        updateRecommendationOptions();
      }

      // Valoración global como media de los totales
      function updateOverall() {
        const techTotal = toNumber(
          document.querySelector('input[name="tech_total"]')?.value,
        );
        const tactTotal = toNumber(
          document.querySelector('input[name="tact_total"]')?.value,
        );
        const physTotal = toNumber(
          document.querySelector('input[name="phys_total"]')?.value,
        );
        const psychTotal = toNumber(
          document.querySelector('input[name="psych_total"]')?.value,
        );
        const persTotal = toNumber(
          document.querySelector('input[name="pers_total"]')?.value,
        );

        const values = [
          techTotal,
          tactTotal,
          physTotal,
          psychTotal,
          persTotal,
        ].filter((v) => v !== null);

        const overallInput = document.querySelector(
          'input[name="overall_rating"]',
        );
        if (!overallInput) return;
        if (!values.length) {
          overallInput.value = '';
          return;
        }
        const sum = values.reduce((a, b) => a + b, 0);
        overallInput.value = (sum / values.length).toFixed(2);
      }

      ['tech_total', 'tact_total', 'phys_total', 'psych_total', 'pers_total']
        .map((name) => document.querySelector(`input[name="${name}"]`))
        .filter(Boolean)
        .forEach((input) => {
          input.addEventListener('input', updateOverall);
        });

      updateOverall();

      function updatePitch() {
        const primary = document
          .querySelector('input[name="pos1"]')
          ?.value.trim()
          .toUpperCase();
        const secondaryCodes = [
          document.querySelector('input[name="pos2"]'),
          document.querySelector('input[name="pos3"]'),
          document.querySelector('input[name="pos4"]'),
        ]
          .filter(Boolean)
          .map((el) => el.value.trim().toUpperCase())
          .filter((v) => v);

        document.querySelectorAll('[data-position-code]').forEach((el) => {
          const code = (el.dataset.positionCode || '').toUpperCase();
          el.classList.remove('selected', 'secondary');

          if (primary && code === primary) {
            el.classList.add('selected');
            return;
          }

          if (secondaryCodes.includes(code)) {
            el.classList.add('secondary');
          }
        });
      }

      ['pos1', 'pos2', 'pos3', 'pos4'].forEach((name) => {
        const el = document.querySelector(`input[name="${name}"]`);
        if (el) {
          el.addEventListener('input', updatePitch);
        }
      });

      updatePitch();
    });
  })();
</script>
