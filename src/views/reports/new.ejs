          <input
            type="text"
            name="team"
            class="form-control"
            value="<%= (formData && formData.team) || '' %>"
          />
        </div>
      </div>
      <div class="row mb-3">
        <div class="col-12">
          <label class="form-label">Contacto</label>
          <input
            type="text"
            name="contact"
            class="form-control"
            value="<%= (formData && formData.contact) || '' %>"
          />
        </div>
      </div>
      <div class="row mb-2">
        <div class="col-md-6">
          <label class="form-label">Posición 1</label>
          <input
            type="text"
            name="pos1"
            class="form-control"
            value="<%= (formData && formData.pos1) || '' %>"
          />
        </div>
        <div class="col-md-6">
          <label class="form-label">Posición 2</label>
          <input
            type="text"
            name="pos2"
            class="form-control"
