<h1 class="mb-4">Nuevo informe</h1>

<form method="POST" action="/reports/new">
  <div class="row mb-3">
    <div class="col-md-6 mb-3">
      <label class="form-label">Seleccionar jugador (opcional)</label>
      <select id="playerSelect" class="form-select">
        <option value="">-- Selecciona un jugador --</option>
        <% if (typeof players !== 'undefined' && players && players.length) { %>
          <% players.forEach(function (p) { %>
            <option
              value="<%= p.id %>"
              data-first-name="<%= p.first_name %>"
              data-last-name="<%= p.last_name %>"
              data-team="<%= p.team || '' %>"
              data-year="<%= p.birth_year || '' %>"
              data-laterality="<%= p.laterality || '' %>"
            >
              <%= p.first_name %> <%= p.last_name %> (<%= p.team || 'Sin equipo' %>)
            </option>
          <% }) %>
        <% } %>
      </select>
      <small class="text-muted">
        Al seleccionar un jugador se rellenarán automáticamente nombre, apellidos, equipo, año y lateralidad.
      </small>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-4">
      <label class="form-label">Nombre <span class="text-danger">*</span></label>
      <input
        type="text"
        name="player_name"
        class="form-control <%= validationErrors.player_name ? 'is-invalid' : '' %>"
        value="<%= (formData && formData.player_name) || '' %>"
        required
        aria-required="true"
      />
      <% if (validationErrors.player_name) { %>
      <div class="invalid-feedback">El nombre es obligatorio.</div>
      <% } %>
    </div>
    <div class="col-md-4">
      <label class="form-label">Apellidos <span class="text-danger">*</span></label>
      <input
        type="text"
        name="player_surname"
        class="form-control <%= validationErrors.player_surname ? 'is-invalid' : '' %>"
        value="<%= (formData && formData.player_surname) || '' %>"
        required
        aria-required="true"
      />
      <% if (validationErrors.player_surname) { %>
      <div class="invalid-feedback">Los apellidos son obligatorios.</div>
      <% } %>
    </div>
    <div class="col-md-2">
      <label class="form-label">Año</label>
      <input
        type="number"
        name="year"
        class="form-control"
        value="<%= (formData && formData.year) || '' %>"
      />
    </div>
    <div class="col-md-2">
      <label class="form-label">Lateralidad</label>
      <input
        type="text"
        name="laterality"
        class="form-control"
        value="<%= (formData && formData.laterality) || '' %>"
      />
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-6">
      <div class="row mb-3">
        <div class="col-12">
          <label class="form-label">Club</label>
          <input
            type="text"
            name="club"
            class="form-control"
            value="<%= (formData && formData.club) || '' %>"
