<h1 class="mb-4">
  Editar informe de <%= report.player_name %> <%= report.player_surname %>
</h1>

<div class="mb-3">
  <a href="/reports/<%= report.id %>" class="btn btn-secondary btn-sm"
    >Cancelar</a
  >
</div>

<form method="POST" action="/reports/<%= report.id %>/edit">
  <div class="row mb-3">
    <div class="col-md-4">
      <label class="form-label">Nombre</label>
      <input
        type="text"
        name="player_name"
        class="form-control"
        value="<%= report.player_name %>"
        required
      />
    </div>
    <div class="col-md-4">
      <label class="form-label">Apellidos</label>
      <input
        type="text"
        name="player_surname"
        class="form-control"
        value="<%= report.player_surname %>"
        required
      />
    </div>
    <div class="col-md-2">
      <label class="form-label">Año</label>
      <input
        type="number"
        name="year"
        class="form-control"
        value="<%= report.year || '' %>"
      />
    </div>
    <div class="col-md-2">
      <label class="form-label">Lateralidad</label>
      <input
        type="text"
        name="laterality"
        class="form-control"
        value="<%= report.laterality || '' %>"
      />
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-4">
      <label class="form-label">Club</label>
      <input
        type="text"
        name="club"
        class="form-control"
        value="<%= report.club || '' %>"
      />
    </div>
    <div class="col-md-4">
      <label class="form-label">Equipo</label>
      <input
        type="text"
        name="team"
        class="form-control"
        value="<%= report.team || '' %>"
      />
    </div>
    <div class="col-md-4">
      <label class="form-label">Contacto</label>
      <input
        type="text"
        name="contact"
        class="form-control"
        value="<%= report.contact || '' %>"
      />
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-3">
      <label class="form-label">Posición 1</label>
      <input
        type="text"
        name="pos1"
        class="form-control"
        value="<%= report.pos1 || '' %>"
      />
    </div>
    <div class="col-md-3">
      <label class="form-label">Posición 2</label>
      <input
        type="text"
        name="pos2"
        class="form-control"
        value="<%= report.pos2 || '' %>"
      />
    </div>
    <div class="col-md-3">
      <label class="form-label">Posición 3</label>
      <input
        type="text"
        name="pos3"
        class="form-control"
        value="<%= report.pos3 || '' %>"
      />
    </div>
    <div class="col-md-3">
      <label class="form-label">Posición 4</label>
      <input
        type="text"
        name="pos4"
        class="form-control"
        value="<%= report.pos4 || '' %>"
      />
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-3">
      <label class="form-label">Recomendación</label>
      <input
        type="text"
        name="recommendation"
        class="form-control"
        value="<%= report.recommendation || '' %>"
      />
    </div>
    <div class="col-md-3">
      <label class="form-label">Fiabilidad info</label>
      <input
        type="number"
        step="0.01"
        name="info_reliability"
        class="form-control"
        value="<%= report.info_reliability || '' %>"
      />
    </div>
  </div>

  <div class="mb-3">
    <label class="form-label">Comentarios</label>
    <textarea
      name="comments"
      rows="4"
      class="form-control"
    ><%= report.comments || '' %></textarea>
  </div>

  <button type="submit" class="btn btn-primary">Guardar cambios</button>
</form>

