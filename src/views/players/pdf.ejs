<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/player-pdf.css" />
    <style>
      :root {
        --pdf-brand-primary: <%= report.brandingColor || '#0F3D2E' %>;
      }
    </style>
  </head>
  <body class="player-pdf-body">
    <% if (previewMode) { %>
      <div class="pdf-preview-toolbar">
        <div>
          <strong>Previsualización PDF</strong>
          <span class="text-muted">Usa imprimir o Guardar como PDF.</span>
        </div>
        <div class="d-flex gap-2">
          <a href="/players/<%= report.player.id %>" class="btn btn-outline-secondary btn-sm">Volver al perfil</a>
          <button type="button" class="btn btn-primary btn-sm" onclick="window.print()">Imprimir / Guardar PDF</button>
        </div>
      </div>
    <% } %>

    <main class="player-pdf-sheet">
      <header class="pdf-header">
        <div class="pdf-brand">
          <img src="<%= report.logoPath %>" alt="<%= report.club.name %>" class="pdf-logo" />
          <div>
            <div class="pdf-kicker">Comunicación trimestral</div>
            <h1>Informe de <%= report.player.fullName %></h1>
            <div class="pdf-subtitle"><%= report.club.name %> · <%= report.seasonLabel %></div>
          </div>
        </div>
        <div class="pdf-header-meta">
          <div><span>Equipo</span><strong><%= report.player.team_name || 'Sin equipo' %></strong></div>
          <div><span>Categoría</span><strong><%= report.player.category_name || '-' %></strong></div>
        </div>
      </header>

      <section class="pdf-grid pdf-grid--top">
        <article class="pdf-card">
          <h2>Identidad del jugador</h2>
          <div class="pdf-player-block">
            <div class="pdf-avatar" style="<%= report.player.avatar_color ? 'background:' + report.player.avatar_color : '' %>">
              <%= report.player.initials %>
            </div>
            <div class="pdf-player-meta">
              <div class="pdf-player-name"><%= report.player.fullName %></div>
              <div class="pdf-chip-row">
                <span class="pdf-chip">#<%= report.player.dorsal || '-' %></span>
                <span class="pdf-chip"><%= report.player.primaryPosition || 'Sin posición' %></span>
                <span class="pdf-chip"><%= report.player.preferredFoot || 'Pie no informado' %></span>
              </div>
            </div>
          </div>
          <dl class="pdf-detail-grid">
            <div><dt>Fecha de nacimiento</dt><dd><%= report.player.birthDateLabel %></dd></div>
            <div><dt>Edad</dt><dd><%= report.player.age != null ? report.player.age : '-' %></dd></div>
            <div><dt>Equipo</dt><dd><%= report.player.team_name || '-' %></dd></div>
            <div><dt>Posición</dt><dd><%= report.player.primaryPosition || '-' %></dd></div>
            <div><dt>Pie preferente</dt><dd><%= report.player.preferredFoot || '-' %></dd></div>
            <div><dt>Sección</dt><dd><%= report.player.section_name || '-' %></dd></div>
          </dl>
        </article>

        <article class="pdf-card">
          <h2>Desarrollo técnico</h2>
          <% if (!report.analytics.history.totalEvaluations) { %>
            <p class="pdf-empty">Todavía no hay evaluaciones suficientes para mostrar una fotografía técnica completa.</p>
          <% } else { %>
            <div class="pdf-overall-row">
              <div>
                <span>Media global</span>
                <strong><%= report.analytics.overallAverageLabel %></strong>
              </div>
              <div>
                <span>Última evaluación</span>
                <strong><%= report.analytics.lastEvaluationDateLabel %></strong>
              </div>
            </div>
            <div class="pdf-radar-wrap">
              <canvas id="playerPdfRadarChart" height="220"></canvas>
            </div>
            <div class="pdf-area-list">
              <% report.analytics.averageByArea.forEach((area) => { %>
                <div class="pdf-area-row">
                  <span><%= area.label %></span>
                  <strong><%= area.average.toFixed(2) %></strong>
                </div>
              <% }) %>
            </div>
          <% } %>
          <% if (report.reports.latestRadar) { %>
            <div class="pdf-report-radar-block">
              <div class="pdf-report-radar-header">
                <div>
                  <span>Último informe</span>
                  <strong><%= report.reports.latestRadar.dateLabel %></strong>
                </div>
                <div>
                  <span>Equipo</span>
                  <strong><%= report.reports.latestRadar.teamLabel %></strong>
                </div>
              </div>
              <div class="pdf-radar-wrap pdf-radar-wrap--report">
                <canvas id="playerPdfReportRadarChart" height="220"></canvas>
              </div>
            </div>
          <% } %>
        </article>
      </section>

      <section class="pdf-grid pdf-grid--bottom">
        <article class="pdf-card">
          <h2>Comentario del cuerpo técnico</h2>
          <% if (!report.coachNote) { %>
            <p class="pdf-empty">No hay comentarios recientes disponibles para este trimestre.</p>
          <% } else { %>
            <p class="pdf-note"><%= report.coachNote %></p>
          <% } %>
        </article>

        <article class="pdf-card">
          <h2>Seguimiento y actividad</h2>
          <div class="pdf-stats-grid">
            <div><span>Total evaluaciones</span><strong><%= report.analytics.history.totalEvaluations %></strong></div>
            <div><span>Última evaluación</span><strong><%= report.analytics.lastEvaluationDateLabel %></strong></div>
            <div><span>Informes registrados</span><strong><%= report.reports.count %></strong></div>
            <div><span>Temporada</span><strong><%= report.seasonLabel %></strong></div>
          </div>
          <div class="pdf-progress-list">
            <% report.progressItems.forEach((item) => { %>
              <div class="pdf-progress-item">
                <div class="d-flex justify-content-between">
                  <span><%= item.label %></span>
                  <strong><%= item.text %></strong>
                </div>
                <div class="progress" role="progressbar" aria-valuenow="<%= item.value %>" aria-valuemin="0" aria-valuemax="100">
                  <div class="progress-bar bg-<%= item.tone %>" style="width: <%= item.value %>%"></div>
                </div>
              </div>
            <% }) %>
          </div>
        </article>
      </section>

      <footer class="pdf-footer">
        <span>Generado el <%= report.generatedDateLabel %></span>
        <span><%= report.club.name %></span>
      </footer>
    </main>

    <% if (report.analytics.history.totalEvaluations || report.reports.latestRadar) { %>
      <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
      <script>
        (function () {
          if (typeof Chart === 'undefined') return;

          var evaluationCanvas = document.getElementById('playerPdfRadarChart');
          if (evaluationCanvas) {
            var evaluationChartData = <%- report.analytics.radarChartJson %>;
            new Chart(evaluationCanvas, {
              type: 'radar',
              data: evaluationChartData,
              options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: false,
                plugins: {
                  legend: { display: false }
                },
                scales: {
                  r: {
                    min: 0,
                    max: 10,
                    ticks: { stepSize: 2, backdropColor: 'transparent' },
                    pointLabels: { font: { size: 11 } }
                  }
                }
              }
            });
          }

          var reportCanvas = document.getElementById('playerPdfReportRadarChart');
          if (reportCanvas) {
            var reportChartData = <%- report.reports.latestRadar ? report.reports.latestRadar.chartJson : 'null' %>;
            new Chart(reportCanvas, {
              type: 'radar',
              data: reportChartData,
              options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: false,
                plugins: {
                  legend: { display: false }
                },
                scales: {
                  r: {
                    min: 0,
                    max: 10,
                    ticks: { stepSize: 2, backdropColor: 'transparent' },
                    pointLabels: { font: { size: 11 } }
                  }
                }
              }
            });
          }
        })();
      </script>
    <% } %>
  </body>
</html>
