<h1 class="mb-4">Editar jugador</h1>

<form method="POST" action="/admin/players/<%= player.id %>/edit" enctype="multipart/form-data">
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Informacion personal</h2>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label" for="first_name">Nombre</label>
          <input type="text" class="form-control" id="first_name" name="first_name" value="<%= player.first_name || '' %>" required />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="last_name">Apellidos</label>
          <input type="text" class="form-control" id="last_name" name="last_name" value="<%= player.last_name || '' %>" required />
        </div>
        <div class="col-md-4">
          <label class="form-label" for="birth_date">Fecha de nacimiento</label>
          <input type="date" class="form-control" id="birth_date" name="birth_date" value="<%= player.birth_date ? player.birth_date.toISOString().slice(0, 10) : '' %>" />
        </div>
        <div class="col-md-4">
          <label class="form-label" for="birth_year">Año de nacimiento</label>
          <input type="number" class="form-control" id="birth_year" name="birth_year" value="<%= player.birth_year || '' %>" />
        </div>
        <div class="col-md-4">
          <label class="form-label" for="nationality">Nacionalidad</label>
          <input type="text" class="form-control" id="nationality" name="nationality" value="<%= player.nationality || '' %>" />
        </div>
        <div class="col-md-4">
          <label class="form-label" for="phone">Telefono</label>
          <input type="text" class="form-control" id="phone" name="phone" value="<%= player.phone || '' %>" />
        </div>
        <div class="col-md-4">
          <label class="form-label" for="email">Email</label>
          <input type="email" class="form-control" id="email" name="email" value="<%= player.email || '' %>" />
        </div>
        <div class="col-md-4">
          <label class="form-label" for="preferred_foot">Pie preferente</label>
          <input type="text" class="form-control" id="preferred_foot" name="preferred_foot" value="<%= player.preferred_foot || '' %>" />
        </div>
        <div class="col-md-4">
          <label class="form-label" for="laterality">Lateralidad</label>
          <input type="text" class="form-control" id="laterality" name="laterality" value="<%= player.laterality || '' %>" />
        </div>
        <div class="col-md-8">
          <label class="form-label" for="photo_file">Foto del jugador</label>
          <input type="file" class="form-control" id="photo_file" name="photo_file" accept="image/*" />
          <div class="form-text">Opcional. Si subes una nueva imagen sustituirá a la actual.</div>
          <% if (player.photo_path) { %>
            <div class="d-flex align-items-center gap-3 mt-3">
              <img src="<%= player.photo_path %>" alt="Foto actual de <%= player.first_name %> <%= player.last_name %>" class="player-form-photo-preview" />
              <div class="form-check">
                <input class="form-check-input" type="checkbox" value="1" id="remove_photo" name="remove_photo" />
                <label class="form-check-label" for="remove_photo">Quitar foto actual</label>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Contexto futbolistico</h2>
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label" for="team_id">Equipo</label>
          <select class="form-select" id="team_id" name="team_id">
            <% if (canManageClubPlayers) { %>
              <option value="">Sin asignar</option>
            <% } %>
            <% teamOptions.forEach((team) => { %>
              <option
                value="<%= team.id %>"
                data-category="<%= team.categoryName %>"
                <%= player.current_team_id === team.id ? 'selected' : '' %>
              >
                <%= team.label %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label" for="category_display">Categoria</label>
          <input type="text" class="form-control" id="category_display" value="<%= player.category_name || '' %>" readonly />
          <div class="form-text">La categoria se toma de la plantilla seleccionada.</div>
        </div>
        <div class="col-md-2">
          <label class="form-label" for="dorsal">Dorsal</label>
          <input type="text" class="form-control" id="dorsal" name="dorsal" value="<%= player.dorsal || '' %>" maxlength="10" />
        </div>
        <div class="col-md-3">
          <label class="form-label" for="positions">Posiciones</label>
          <input type="text" class="form-control" id="positions" name="positions" value="<%= player.positions || '' %>" placeholder="Ej. MC, MP, EI" />
          <div class="form-text">Puedes indicar varias posiciones separadas por comas.</div>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Estadisticas</h2>
      <div class="row g-3">
        <div class="col-md-3">
          <label class="form-label" for="stats_callups">Convocados</label>
          <input type="number" class="form-control" id="stats_callups" name="stats_callups" value="<%= player.stats && player.stats.callups != null ? player.stats.callups : '' %>" min="0" />
        </div>
        <div class="col-md-3">
          <label class="form-label" for="stats_starts">Titular</label>
          <input type="number" class="form-control" id="stats_starts" name="stats_starts" value="<%= player.stats && player.stats.starts != null ? player.stats.starts : '' %>" min="0" />
        </div>
        <div class="col-md-3">
          <label class="form-label" for="stats_substitute_appearances">Suplente</label>
          <input type="number" class="form-control" id="stats_substitute_appearances" name="stats_substitute_appearances" value="<%= player.stats && player.stats.substituteAppearances != null ? player.stats.substituteAppearances : '' %>" min="0" />
        </div>
        <div class="col-md-3">
          <label class="form-label" for="stats_unused_callups">S/Jugar</label>
          <input type="number" class="form-control" id="stats_unused_callups" name="stats_unused_callups" value="<%= player.stats && player.stats.unusedCallups != null ? player.stats.unusedCallups : '' %>" min="0" />
        </div>
        <div class="col-md-3">
          <label class="form-label" for="stats_not_called_up">No convocado</label>
          <input type="number" class="form-control" id="stats_not_called_up" name="stats_not_called_up" value="<%= player.stats && player.stats.notCalledUp != null ? player.stats.notCalledUp : '' %>" min="0" />
        </div>
        <div class="col-md-3">
          <label class="form-label" for="stats_minutes">Minutos</label>
          <input type="number" class="form-control" id="stats_minutes" name="stats_minutes" value="<%= player.stats && player.stats.minutes != null ? player.stats.minutes : '' %>" min="0" />
        </div>
        <div class="col-md-3">
          <label class="form-label" for="stats_goals">Goles</label>
          <input type="number" class="form-control" id="stats_goals" name="stats_goals" value="<%= player.stats && player.stats.goals != null ? player.stats.goals : '' %>" min="0" />
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4 d-flex gap-2">
    <button type="submit" class="btn btn-sr-primary">Guardar cambios</button>
    <a href="/admin/players" class="btn btn-secondary">Cancelar</a>
  </div>
</form>

<script>
  (function () {
    var teamSelect = document.getElementById('team_id');
    var categoryField = document.getElementById('category_display');
    if (!teamSelect || !categoryField) return;

    function syncCategory() {
      var option = teamSelect.options[teamSelect.selectedIndex];
      categoryField.value = option ? (option.getAttribute('data-category') || '') : '';
    }

    teamSelect.addEventListener('change', syncCategory);
    syncCategory();
  })();
</script>
