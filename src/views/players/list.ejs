<h1 class="mb-4">Base de jugadores</h1>

<%
  function buildPlayersQuery(overrides) {
    const params = new URLSearchParams();
    const next = Object.assign({}, filters || {}, overrides || {});
    Object.keys(next).forEach(function (key) {
      var value = next[key];
      if (value !== undefined && value !== null && String(value) !== '') {
        params.set(key, String(value));
      }
    });
    return params.toString() ? '?' + params.toString() : '';
  }

  function sortLink(field) {
    var nextDir = sort && sort.field === field && sort.direction === 'asc' ? 'desc' : 'asc';
    return '/admin/players' + buildPlayersQuery({ sort: field, dir: nextDir, page: 1 });
  }

  function sortIndicator(field) {
    if (!sort || sort.field !== field) {
      return '↕';
    }
    return sort.direction === 'asc' ? '↑' : '↓';
  }
%>

<div class="mb-3 d-flex gap-2">
  <a href="/admin/players/new" class="btn btn-sr-primary">Nuevo jugador</a>
  <% if (canManageClubPlayers) { %>
    <a href="/admin/players/import" class="btn btn-sr-outline">
      Importar desde Excel
    </a>
  <% } %>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <form method="GET" action="/admin/players" class="row g-3 align-items-end">
      <div class="col-md-4">
        <label for="team_id" class="form-label">Equipo</label>
        <select id="team_id" name="team_id" class="form-select">
          <option value="">Todos</option>
          <% (filterOptions && filterOptions.teams ? filterOptions.teams : []).forEach(function (team) { %>
            <option value="<%= team.id %>" <%= String(filters && filters.teamId || '') === String(team.id) ? 'selected' : '' %>><%= team.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label for="laterality" class="form-label">Lateralidad</label>
        <select id="laterality" name="laterality" class="form-select">
          <option value="">Todas</option>
          <% (filterOptions && filterOptions.lateralities ? filterOptions.lateralities : []).forEach(function (laterality) { %>
            <option value="<%= laterality %>" <%= String(filters && filters.laterality || '') === String(laterality) ? 'selected' : '' %>><%= laterality %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label for="birth_year" class="form-label">Año de nacimiento</label>
        <select id="birth_year" name="birth_year" class="form-select">
          <option value="">Todos</option>
          <% (filterOptions && filterOptions.birthYears ? filterOptions.birthYears : []).forEach(function (year) { %>
            <option value="<%= year %>" <%= String(filters && filters.birthYear || '') === String(year) ? 'selected' : '' %>><%= year %></option>
          <% }) %>
        </select>
      </div>
      <input type="hidden" name="sort" value="<%= sort ? sort.field : 'created_at' %>" />
      <input type="hidden" name="dir" value="<%= sort ? sort.direction : 'desc' %>" />
      <div class="col-md-2 d-flex gap-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Filtrar</button>
      </div>
      <div class="col-12">
        <a href="/admin/players" class="btn btn-link px-0">Limpiar</a>
      </div>
    </form>
  </div>
</div>

<% if (pagination) { %>
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <p class="text-muted mb-0">
      Mostrando <%= pagination.startItem %>-<%= pagination.endItem %> de <%= pagination.totalItems %> jugadores
    </p>
    <p class="text-muted mb-0">
      Página <%= pagination.page %> de <%= pagination.totalPages %>
    </p>
  </div>
<% } %>

<% if (!players || !players.length) { %>
<p>No hay jugadores registrados.</p>
<% } else { %>
<% if (canManageClubPlayers) { %>
<form
  method="POST"
  action="/admin/players/bulk-delete"
  onsubmit="return confirm('¿Seguro que quieres borrar los jugadores seleccionados?');"
>
  <div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
      <thead>
        <tr>
          <th>
            <input type="checkbox" id="selectAllPlayers" />
          </th>
          <th><a class="table-sort-link" href="<%= sortLink('id') %>">ID <span><%= sortIndicator('id') %></span></a></th>
          <th><a class="table-sort-link" href="<%= sortLink('first_name') %>">Nombre <span><%= sortIndicator('first_name') %></span></a></th>
          <th><a class="table-sort-link" href="<%= sortLink('last_name') %>">Apellidos <span><%= sortIndicator('last_name') %></span></a></th>
          <th><a class="table-sort-link" href="<%= sortLink('team') %>">Equipo <span><%= sortIndicator('team') %></span></a></th>
          <th><a class="table-sort-link" href="<%= sortLink('dorsal') %>">Dorsal <span><%= sortIndicator('dorsal') %></span></a></th>
          <th><a class="table-sort-link" href="<%= sortLink('birth_year') %>">Año nacimiento <span><%= sortIndicator('birth_year') %></span></a></th>
          <th><a class="table-sort-link" href="<%= sortLink('laterality') %>">Lateralidad <span><%= sortIndicator('laterality') %></span></a></th>
          <th><a class="table-sort-link" href="<%= sortLink('created_at') %>">Creado <span><%= sortIndicator('created_at') %></span></a></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% players.forEach(function (p) { %>
        <tr>
          <td>
            <input
              type="checkbox"
              class="player-select"
              name="playerIds"
              value="<%= p.id %>"
            />
          </td>
          <td><%= p.id %></td>
          <td>
            <div class="player-list-name">
              <% if (p.photo_path) { %>
                <img
                  src="<%= p.photo_path %>"
                  alt="Foto de <%= p.first_name %> <%= p.last_name %>"
                  class="player-list-avatar"
                />
              <% } else { %>
                <span class="player-list-avatar player-list-avatar--fallback">
                  <%= `${(p.first_name || '').charAt(0)}${(p.last_name || '').charAt(0)}`.toUpperCase() %>
                </span>
              <% } %>
              <span><%= p.first_name %></span>
            </div>
          </td>
          <td><%= p.last_name %></td>
          <td><%= p.relational_team_name || 'Sin equipo' %></td>
          <td><%= p.dorsal || '' %></td>
          <td><%= p.birth_year || '' %></td>
          <td><%= p.laterality || '' %></td>
          <td>
            <%= p.created_at ? new Date(p.created_at).toISOString().slice(0, 10) : '' %>
          </td>
          <td class="text-nowrap d-flex gap-2">
            <a
              href="/admin/players/<%= p.id %>/edit"
              class="btn btn-sm btn-outline-secondary"
            >
              Editar
            </a>
            <form
              method="POST"
              action="/admin/players/<%= p.id %>/delete"
              onsubmit="return confirm('¿Seguro que quieres borrar este jugador?');"
            >
              <button type="submit" class="btn btn-sm btn-outline-danger">
                Borrar
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="mt-3">
    <button type="submit" class="btn btn-danger btn-sm">
      Borrar seleccionados
    </button>
  </div>
</form>
<% } else { %>
<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead>
      <tr>
        <th><a class="table-sort-link" href="<%= sortLink('id') %>">ID <span><%= sortIndicator('id') %></span></a></th>
        <th><a class="table-sort-link" href="<%= sortLink('first_name') %>">Nombre <span><%= sortIndicator('first_name') %></span></a></th>
        <th><a class="table-sort-link" href="<%= sortLink('last_name') %>">Apellidos <span><%= sortIndicator('last_name') %></span></a></th>
        <th><a class="table-sort-link" href="<%= sortLink('team') %>">Equipo <span><%= sortIndicator('team') %></span></a></th>
        <th><a class="table-sort-link" href="<%= sortLink('dorsal') %>">Dorsal <span><%= sortIndicator('dorsal') %></span></a></th>
        <th><a class="table-sort-link" href="<%= sortLink('birth_year') %>">Año nacimiento <span><%= sortIndicator('birth_year') %></span></a></th>
        <th><a class="table-sort-link" href="<%= sortLink('laterality') %>">Lateralidad <span><%= sortIndicator('laterality') %></span></a></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% players.forEach(function (p) { %>
      <tr>
        <td><%= p.id %></td>
        <td>
          <div class="player-list-name">
            <% if (p.photo_path) { %>
              <img
                src="<%= p.photo_path %>"
                alt="Foto de <%= p.first_name %> <%= p.last_name %>"
                class="player-list-avatar"
              />
            <% } else { %>
              <span class="player-list-avatar player-list-avatar--fallback">
                <%= `${(p.first_name || '').charAt(0)}${(p.last_name || '').charAt(0)}`.toUpperCase() %>
              </span>
            <% } %>
            <span><%= p.first_name %></span>
          </div>
        </td>
        <td><%= p.last_name %></td>
        <td><%= p.relational_team_name || 'Sin equipo' %></td>
        <td><%= p.dorsal || '' %></td>
        <td><%= p.birth_year || '' %></td>
        <td><%= p.laterality || '' %></td>
        <td class="text-nowrap d-flex gap-2">
          <a href="/players/<%= p.id %>" class="btn btn-sm btn-outline-secondary">Perfil</a>
          <a href="/admin/players/<%= p.id %>/edit" class="btn btn-sm btn-primary">Editar</a>
          <form
            method="POST"
            action="/admin/players/<%= p.id %>/delete"
            onsubmit="return confirm('¿Seguro que quieres borrar este jugador?');"
          >
            <button type="submit" class="btn btn-sm btn-outline-danger">
              Borrar
            </button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>
<% } %>

<% if (pagination && pagination.totalPages > 1) { %>
  <nav aria-label="Paginación de jugadores" class="mt-4">
    <ul class="pagination flex-wrap">
      <li class="page-item <%= pagination.hasPrev ? '' : 'disabled' %>">
        <a class="page-link" href="<%= pagination.hasPrev ? '/admin/players' + buildPlayersQuery({ page: pagination.page - 1 }) : '#' %>">Anterior</a>
      </li>
      <% for (let pageNumber = 1; pageNumber <= pagination.totalPages; pageNumber += 1) { %>
        <li class="page-item <%= pageNumber === pagination.page ? 'active' : '' %>">
          <a class="page-link" href="/admin/players<%= buildPlayersQuery({ page: pageNumber }) %>"><%= pageNumber %></a>
        </li>
      <% } %>
      <li class="page-item <%= pagination.hasNext ? '' : 'disabled' %>">
        <a class="page-link" href="<%= pagination.hasNext ? '/admin/players' + buildPlayersQuery({ page: pagination.page + 1 }) : '#' %>">Siguiente</a>
      </li>
    </ul>
  </nav>
<% } %>

<script>
  (function () {
    var selectAll = document.getElementById('selectAllPlayers');
    if (!selectAll) return;
    selectAll.addEventListener('change', function () {
      var checks = document.querySelectorAll('input.player-select');
      checks.forEach(function (c) {
        c.checked = selectAll.checked;
      });
    });
  })();
</script>
