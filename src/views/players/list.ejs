<h1 class="mb-4">Base de jugadores</h1>

<% if (!players || !players.length) { %>
<p>No hay jugadores registrados.</p>
<% } else { %>
<form
  method="POST"
  action="/admin/players/bulk-delete"
  onsubmit="return confirm('¿Seguro que quieres borrar los jugadores seleccionados?');"
>
  <div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
      <thead>
        <tr>
          <th>
            <input type="checkbox" id="selectAllPlayers" />
          </th>
          <th>ID</th>
          <th>Nombre</th>
          <th>Apellidos</th>
          <th>Equipo</th>
          <th>Año nacimiento</th>
          <th>Lateralidad</th>
          <th>Creado</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% players.forEach(function (p) { %>
        <tr>
          <td>
            <input
              type="checkbox"
              class="player-select"
              name="playerIds"
              value="<%= p.id %>"
            />
          </td>
          <td><%= p.id %></td>
          <td><%= p.first_name %></td>
          <td><%= p.last_name %></td>
          <td><%= p.team || '' %></td>
          <td><%= p.birth_year || '' %></td>
          <td><%= p.laterality || '' %></td>
          <td>
            <%= p.created_at ? new Date(p.created_at).toISOString().slice(0, 10) : '' %>
          </td>
          <td class="text-nowrap d-flex gap-2">
            <a
              href="/admin/players/<%= p.id %>/edit"
              class="btn btn-sm btn-outline-secondary"
            >
              Editar
            </a>
            <form
              method="POST"
              action="/admin/players/<%= p.id %>/delete"
              onsubmit="return confirm('¿Seguro que quieres borrar este jugador?');"
            >
              <button type="submit" class="btn btn-sm btn-outline-danger">
                Borrar
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="mt-3">
    <button type="submit" class="btn btn-danger btn-sm">
      Borrar seleccionados
    </button>
  </div>
</form>
<% } %>

<script>
  (function () {
    var selectAll = document.getElementById('selectAllPlayers');
    if (!selectAll) return;
    selectAll.addEventListener('change', function () {
      var checks = document.querySelectorAll('input.player-select');
      checks.forEach(function (c) {
        c.checked = selectAll.checked;
      });
    });
  })();
</script>

