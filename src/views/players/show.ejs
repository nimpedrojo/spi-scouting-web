    </div>
  </div>
<% } %>

<% if (hasEvaluationHistory) { %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script>
    (function () {
      var canvas = document.getElementById('playerRadarChart');
      if (!canvas || typeof Chart === 'undefined') return;
      var chartData = <%- analytics.radarChartJson %>;
      new Chart(canvas, {
        type: 'radar',
        data: chartData,
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            r: {
              min: 0,
              max: 10,
              ticks: { stepSize: 2 }
            }
          },
          plugins: {
            legend: { display: chartData && Array.isArray(chartData.datasets) && chartData.datasets.length > 1 }
          }
        }
      });
    })();
  </script>
<% } %>

<script>
  (function () {
    var panel = document.querySelector('[data-season-recommendation-panel]');
    if (!panel) return;

    var playerId = panel.getAttribute('data-player-id');
    var activeSeasonId = panel.getAttribute('data-active-season-id') || '';
    var activeSeasonLabel = panel.getAttribute('data-active-season-label') || 'Temporada activa';
    var defaultTeamLabel = panel.getAttribute('data-team-label') || '';
    var canEdit = panel.getAttribute('data-can-edit') === 'true';

    var currentContainer = panel.querySelector('[data-season-recommendation-current]');
    var historyContainer = panel.querySelector('[data-season-recommendation-history]');
    var historyCount = panel.querySelector('[data-season-recommendation-history-count]');
    var form = panel.querySelector('[data-season-recommendation-form]');
    var seasonSelect = panel.querySelector('[data-season-recommendation-season]');
    var statusSelect = panel.querySelector('[data-season-recommendation-status]');
    var teamInput = panel.querySelector('[data-season-recommendation-team]');
    var notesInput = panel.querySelector('[data-season-recommendation-notes]');
    var feedback = panel.querySelector('[data-season-recommendation-feedback]');
    var submitButton = panel.querySelector('[data-season-recommendation-submit]');

    var seasonRegistry = {};
    if (activeSeasonId) {
      seasonRegistry[activeSeasonId] = activeSeasonLabel;
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function getStatusLabel(status) {
      if (status === 'in_review') return 'In review';
      if (status === 'validated') return 'Validated';
      if (status === 'discarded') return 'Discarded';
      return 'Proposed';
    }

    function getSeasonLabel(recommendation) {
      if (!recommendation) return '-';
      return seasonRegistry[recommendation.season_id] || recommendation.season_id || 'Temporada no disponible';
    }

    function getTeamLabel(recommendation) {
      return recommendation.recommended_team_name || recommendation.recommended_team_label || 'Sin definir';
    }

    function formatDate(value) {
      if (!value) return '';
      return String(value).slice(0, 10);
    }

    function renderCurrentRecommendation(recommendations) {
      if (!recommendations.length) {
        currentContainer.innerHTML = ''
          + '<div class="season-recommendation-empty">'
          + '<div class="fw-semibold mb-1">Sin recomendación registrada</div>'
          + '<div class="text-muted">Usa el formulario para dejar la primera propuesta de próxima temporada.</div>'
          + '</div>';
        return;
      }

      var recommendation = recommendations[0];
      currentContainer.innerHTML = ''
        + '<div class="season-recommendation-highlight">'
        + '  <div class="d-flex justify-content-between align-items-start gap-3 mb-3">'
        + '    <div>'
        + '      <div class="season-recommendation-label">Temporada destino</div>'
        + '      <div class="season-recommendation-value">' + escapeHtml(getSeasonLabel(recommendation)) + '</div>'
        + '    </div>'
        + '    <span class="season-recommendation-status season-recommendation-status--' + escapeHtml(recommendation.status || 'proposed') + '">'
        +        escapeHtml(getStatusLabel(recommendation.status)) + '</span>'
        + '  </div>'
        + '  <div class="season-recommendation-meta">'
        + '    <div><span>Equipo recomendado</span><strong>' + escapeHtml(getTeamLabel(recommendation)) + '</strong></div>'
        + '    <div><span>Notas</span><strong>' + escapeHtml(recommendation.notes || 'Sin notas') + '</strong></div>'
        + '    <div><span>Actualizado</span><strong>' + escapeHtml(formatDate(recommendation.updated_at || recommendation.created_at)) + '</strong></div>'
        + '  </div>'
        + '</div>';
    }

    function renderHistory(recommendations) {
      historyCount.textContent = recommendations.length
        ? recommendations.length + ' recomendación' + (recommendations.length === 1 ? '' : 'es')
        : 'Sin histórico';

      if (!recommendations.length) {
        historyContainer.innerHTML = '<div class="season-recommendation-empty text-muted">Todavía no hay histórico disponible.</div>';
        return;
      }

      historyContainer.innerHTML = recommendations.map(function (recommendation) {
        return ''
          + '<article class="season-recommendation-history-item">'
          + '  <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">'
          + '    <div class="fw-semibold">' + escapeHtml(getSeasonLabel(recommendation)) + '</div>'
          + '    <span class="season-recommendation-status season-recommendation-status--' + escapeHtml(recommendation.status || 'proposed') + '">'
          +        escapeHtml(getStatusLabel(recommendation.status)) + '</span>'
          + '  </div>'
          + '  <div class="small text-muted mb-2">Equipo: ' + escapeHtml(getTeamLabel(recommendation)) + '</div>'
          + '  <div class="small">' + escapeHtml(recommendation.notes || 'Sin notas registradas.') + '</div>'
          + '</article>';
      }).join('');
    }

    function buildSeasonOptions(recommendations) {
      recommendations.forEach(function (recommendation) {
        if (recommendation && recommendation.season_id && !seasonRegistry[recommendation.season_id]) {
          seasonRegistry[recommendation.season_id] = recommendation.season_id;
        }
      });

      var entries = Object.keys(seasonRegistry).map(function (seasonId) {
        return {
          id: seasonId,
          label: seasonRegistry[seasonId]
        };
      });

      if (!entries.length) {
        seasonSelect.innerHTML = '<option value="">Sin temporadas disponibles</option>';
        seasonSelect.disabled = true;
        submitButton.disabled = true;
        feedback.textContent = 'No hay una temporada disponible en el contexto actual.';
        return;
      }

      seasonSelect.disabled = false;
      submitButton.disabled = !canEdit;
      seasonSelect.innerHTML = entries.map(function (entry) {
        return '<option value="' + escapeHtml(entry.id) + '">' + escapeHtml(entry.label) + '</option>';
      }).join('');

      if (activeSeasonId && seasonRegistry[activeSeasonId]) {
        seasonSelect.value = activeSeasonId;
      }
    }

    async function loadRecommendations() {
      var response = await fetch('/players/' + encodeURIComponent(playerId) + '/recommendations', {
        headers: {
          Accept: 'application/json'
        },
        credentials: 'same-origin'
      });

      if (response.status === 403) {
        throw new Error('No tienes permisos para consultar recomendaciones de este jugador.');
      }

      if (!response.ok) {
        throw new Error('No se pudieron cargar las recomendaciones.');
      }

      return response.json();
    }

    async function refreshView() {
      try {
        feedback.textContent = '';
        var payload = await loadRecommendations();
        var recommendations = Array.isArray(payload.recommendations) ? payload.recommendations : [];
        buildSeasonOptions(recommendations);
        renderCurrentRecommendation(recommendations);
        renderHistory(recommendations);
      } catch (error) {
        currentContainer.innerHTML = '<div class="season-recommendation-empty text-danger">' + escapeHtml(error.message) + '</div>';
        historyContainer.innerHTML = '';
        historyCount.textContent = '';
      }
    }

    form.addEventListener('submit', async function (event) {
      event.preventDefault();

      if (!canEdit) {
        feedback.textContent = 'No tienes permisos para guardar recomendaciones.';
        feedback.className = 'small text-danger';
        return;
      }

      var seasonId = seasonSelect.value;
      var teamLabel = teamInput.value.trim();
      var status = statusSelect.value;
      var notes = notesInput.value.trim();

      if (!seasonId || !teamLabel) {
        feedback.textContent = 'Completa temporada y equipo recomendado.';
        feedback.className = 'small text-danger';
        return;
      }

      feedback.textContent = 'Guardando…';
      feedback.className = 'small text-muted';
      submitButton.disabled = true;

      try {
        var createResponse = await fetch('/season-recommendations', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json'
          },
          credentials: 'same-origin',
          body: JSON.stringify({
            seasonId: seasonId,
            sourceType: 'internal',
            playerId: playerId,
            recommendedTeamLabel: teamLabel,
            notes: notes
          })
        });

        var createdPayload = await createResponse.json();
        if (!createResponse.ok) {
          throw new Error(createdPayload && createdPayload.errors ? createdPayload.errors.join(' ') : 'No se pudo guardar la recomendación.');
        }

        if (status && status !== 'proposed') {
          var updateResponse = await fetch('/season-recommendations/' + encodeURIComponent(createdPayload.id), {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json'
            },
            credentials: 'same-origin',
            body: JSON.stringify({
              recommendedTeamLabel: teamLabel,
              status: status,
              notes: notes
            })
          });

          var updatePayload = await updateResponse.json();
          if (!updateResponse.ok) {
            throw new Error(updatePayload && updatePayload.errors ? updatePayload.errors.join(' ') : 'La recomendación se creó pero no se pudo actualizar el estado.');
          }
        }

        feedback.textContent = 'Recomendación guardada correctamente.';
        feedback.className = 'small text-success';
        notesInput.value = '';
        await refreshView();
      } catch (error) {
        feedback.textContent = error.message;
        feedback.className = 'small text-danger';
      } finally {
        submitButton.disabled = false;
      }
    });

    if (!teamInput.value && defaultTeamLabel) {
      teamInput.value = defaultTeamLabel;
    }

    refreshView();
  })();
</script>
