<%
  const isPmvMode = productModeInfo && productModeInfo.isPmvPlayerTracking;
  const recentEvaluations = analytics && analytics.history && analytics.history.recentEvaluations
    ? analytics.history.recentEvaluations
    : [];
  const trendSummary = trackingSummary && trackingSummary.trend ? trackingSummary.trend : null;
  const latestEvaluationDate = trackingSummary && trackingSummary.lastEvaluationDate
    ? new Date(trackingSummary.lastEvaluationDate)
    : null;
  const latestReportDate = trackingSummary && trackingSummary.lastReportDate
    ? new Date(trackingSummary.lastReportDate)
    : null;
  const latestActivityDate = latestEvaluationDate && latestReportDate
    ? (latestEvaluationDate > latestReportDate ? latestEvaluationDate : latestReportDate)
    : (latestEvaluationDate || latestReportDate || null);
  const hasEvaluationHistory = analytics && analytics.history && analytics.history.totalEvaluations;
  const activeSeasonLabel = player.season_name || (activeSeason ? activeSeason.name : '');
  const activeSeasonId = activeSeason && activeSeason.id ? activeSeason.id : '';
  const playerTeamLabel = player.team_name || '';
  const canEditSeasonRecommendations = Boolean(currentUser && (currentUser.role === 'admin' || currentUser.role === 'superadmin'));
  const availableSeasons = seasonView && Array.isArray(seasonView.seasons) ? seasonView.seasons : [];
  const selectedSeasonId = seasonView && seasonView.selectedSeasonId ? seasonView.selectedSeasonId : activeSeasonId;
%>

<% if (isPmvMode) { %>
  <div class="mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <% if (teamProfileHref) { %>
      <a href="<%= teamProfileHref %>" class="text-decoration-none text-muted d-inline-flex align-items-center gap-2">
        <span aria-hidden="true">←</span>
        <span>Volver al equipo</span>
      </a>
    <% } %>
  </div>

  <section class="card pmv-surface-card pmv-player-hero shadow-sm border-0 mb-4">
    <div class="card-body p-4 p-lg-5">
      <div class="row g-4 align-items-center">
        <div class="col-lg-7">
          <div class="d-flex align-items-center gap-3 flex-wrap">
            <% if (player.photo_path) { %>
              <img
                src="<%= player.photo_path %>"
                alt="Foto de <%= player.full_name %>"
                class="player-avatar player-avatar--photo"
              />
            <% } else { %>
              <div class="player-avatar" style="<%= player.avatar_color ? 'background:' + player.avatar_color : '' %>">
                <%= player.initials %>
              </div>
            <% } %>
            <div>
              <div class="d-inline-flex align-items-center gap-2 flex-wrap mb-2">
                <span class="dashboard-kicker">Jugador activo</span>
                <% if (player.primary_position) { %>
                  <span class="badge rounded-pill text-bg-light border"><%= player.primary_position %></span>
                <% } %>
              </div>
              <h1 class="h2 mb-2"><%= player.full_name %></h1>
              <div class="text-muted mb-3">
                <%= player.team_name || 'Sin equipo' %><% if (player.category_name) { %> · <%= player.category_name %><% } %><% if (player.primary_position) { %> · <%= player.primary_position %><% } %>
              </div>
              <div class="d-flex gap-2 flex-wrap">
                <span class="badge rounded-pill text-bg-light border">Dorsal: <%= player.dorsal || '-' %></span>
                <span class="badge rounded-pill text-bg-light border">Edad: <%= player.age != null ? player.age : '-' %></span>
                <span class="badge rounded-pill text-bg-light border">Lateralidad: <%= player.laterality || '-' %></span>
                <span class="badge rounded-pill text-bg-light border">Temporada: <%= player.season_name || (activeSeason ? activeSeason.name : '-') %></span>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-5">
          <% if (availableSeasons.length) { %>
            <form method="GET" action="/players/<%= player.id %>" class="mb-3 d-flex gap-2 justify-content-lg-end flex-wrap align-items-end">
              <div>
                <label for="playerSeasonSelector" class="form-label small text-muted mb-1">Temporada</label>
                <select id="playerSeasonSelector" name="season_id" class="form-select form-select-sm">
                  <% availableSeasons.forEach((season) => { %>
                    <option value="<%= season.id %>" <%= String(selectedSeasonId || '') === String(season.id) ? 'selected' : '' %>>
                      <%= season.name %><%= season.is_active ? ' · Activa' : '' %>
                    </option>
                  <% }) %>
                </select>
              </div>
              <button type="submit" class="btn btn-sm btn-outline-secondary">Cambiar</button>
            </form>
          <% } %>
          <div class="d-flex gap-2 justify-content-lg-end flex-wrap pmv-hero-actions">
            <% if (scoutingPlayersEnabled) { %>
              <a href="/evaluations/new?team_id=<%= player.current_team_id || '' %>&player_id=<%= player.id %>" class="btn btn-primary">Nueva evaluación</a>
              <a href="/reports/new?team_id=<%= player.current_team_id || '' %>&player_id=<%= player.id %>" class="btn btn-outline-primary">Nuevo informe</a>
            <% } else { %>
              <button type="button" class="btn btn-outline-secondary" disabled>Nueva evaluación</button>
              <button type="button" class="btn btn-outline-secondary" disabled>Nuevo informe</button>
            <% } %>
          </div>

          <div class="d-flex gap-3 justify-content-lg-end flex-wrap mt-3">
            <% if (scoutingPlayersEnabled) { %>
              <a href="/players/<%= player.id %>/pdf/preview" class="small text-decoration-none" target="_blank" rel="noopener">Ver PDF</a>
            <% } %>
            <a href="/players/<%= player.id %>/evaluations" class="small text-decoration-none">Historial completo</a>
            <a href="/admin/players/<%= player.id %>/edit" class="small text-decoration-none">Editar ficha</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-4">
    <div class="row g-4">
      <div class="col-6 col-lg-3">
        <div class="card pmv-insight-card shadow-sm h-100">
          <div class="card-body">
            <div class="small text-uppercase text-muted">Evaluaciones</div>
            <div class="display-6 fw-semibold"><%= trackingSummary.totalEvaluations %></div>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="card pmv-insight-card shadow-sm h-100">
          <div class="card-body">
            <div class="small text-uppercase text-muted">Informes</div>
            <div class="display-6 fw-semibold"><%= trackingSummary.totalReports %></div>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="card pmv-insight-card shadow-sm h-100">
          <div class="card-body">
            <div class="small text-uppercase text-muted">Última actividad</div>
            <div class="fw-semibold mt-2"><%= latestActivityDate ? latestActivityDate.toISOString().slice(0, 10) : 'Sin datos' %></div>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="card pmv-insight-card shadow-sm h-100">
          <div class="card-body">
            <div class="small text-uppercase text-muted">Media global</div>
            <div class="display-6 fw-semibold"><%= trackingSummary.overallAverage !== null ? trackingSummary.overallAverage.toFixed(2) : '-' %></div>
            <% if (trendSummary) { %>
              <div class="small mt-2 <%= trendSummary.direction === 'up' ? 'text-success' : trendSummary.direction === 'down' ? 'text-danger' : 'text-muted' %>">
                <%= trendSummary.delta > 0 ? '+' : '' %><%= trendSummary.delta.toFixed(2) %>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-4">
    <div class="row g-4">
      <div class="col-lg-5">
        <div class="card pmv-surface-card shadow-sm h-100">
          <div class="card-body">
            <h2 class="h5 mb-3">Resumen del jugador</h2>
            <div class="profile-info-grid">
              <div><span class="text-muted">Equipo</span><strong><%= player.team_name || '-' %></strong></div>
              <div><span class="text-muted">Categoria</span><strong><%= player.category_name || '-' %></strong></div>
              <div><span class="text-muted">Posición</span><strong><%= player.primary_position || '-' %></strong></div>
              <div><span class="text-muted">Edad</span><strong><%= player.age != null ? player.age : '-' %></strong></div>
              <div><span class="text-muted">Lateralidad</span><strong><%= player.laterality || '-' %></strong></div>
              <div><span class="text-muted">Temporada</span><strong><%= player.season_name || (activeSeason ? activeSeason.name : '-') %></strong></div>
            </div>

            <% if (!scoutingPlayersEnabled) { %>
              <div class="border rounded-3 bg-light p-3 mt-4">
                <p class="fw-semibold mb-2">Disponible con el módulo Scouting Players</p>
                <p class="text-muted mb-0">Activa el módulo para ver evolución, informes y evaluaciones del jugador.</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="col-lg-7">
        <div class="card pmv-surface-card shadow-sm h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
              <h2 class="h5 mb-0">Cómo va</h2>
              <% if (trendSummary) { %>
                <span class="badge <%= trendSummary.direction === 'up' ? 'text-bg-success' : trendSummary.direction === 'down' ? 'text-bg-danger' : 'text-bg-secondary' %>">
                  <%= trendSummary.label %>
                </span>
              <% } %>
            </div>

            <% if (!scoutingPlayersEnabled) { %>
              <p class="text-muted mb-0">La evolución aparecerá aquí cuando el módulo de seguimiento esté activo.</p>
            <% } else if (!hasEvaluationHistory) { %>
              <p class="text-muted mb-3">Todavía no hay evaluaciones registradas para este jugador.</p>
              <a href="/evaluations/new?team_id=<%= player.current_team_id || '' %>&player_id=<%= player.id %>" class="btn btn-primary">Crear primera evaluación</a>
            <% } else { %>
              <div class="row g-3 mb-4">
                <div class="col-md-4">
                  <div class="pmv-inline-stat h-100">
                    <div class="small text-uppercase text-muted">Última evaluación</div>
                    <div class="fw-semibold mt-1"><%= trackingSummary.lastEvaluationDate ? new Date(trackingSummary.lastEvaluationDate).toISOString().slice(0, 10) : '-' %></div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="pmv-inline-stat h-100">
                    <div class="small text-uppercase text-muted">Último informe</div>
                    <div class="fw-semibold mt-1"><%= trackingSummary.lastReportDate ? new Date(trackingSummary.lastReportDate).toISOString().slice(0, 10) : '-' %></div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="pmv-inline-stat h-100">
                    <div class="small text-uppercase text-muted">Tendencia</div>
                    <div class="fw-semibold mt-1">
                      <%= trendSummary ? `${trendSummary.delta > 0 ? '+' : ''}${trendSummary.delta.toFixed(2)}` : 'Sin dato suficiente' %>
                    </div>
                  </div>
                </div>
              </div>

              <% if (analytics.averageByArea && analytics.averageByArea.length) { %>
                <div class="row g-3">
                  <% analytics.averageByArea.forEach((area) => { %>
                    <div class="col-md-6">
                      <div class="pmv-inline-stat h-100">
                        <div class="d-flex justify-content-between mb-2">
                          <span><%= area.label %></span>
                          <strong><%= area.average.toFixed(2) %></strong>
                        </div>
                        <div class="progress" role="progressbar" aria-label="<%= area.label %>" aria-valuenow="<%= area.average * 10 %>" aria-valuemin="0" aria-valuemax="100">
                          <div class="progress-bar" style="width: <%= Math.max(0, Math.min(100, area.average * 10)) %>%"></div>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-4">
    <div
      class="card pmv-surface-card shadow-sm season-recommendation-card"
      data-season-recommendation-panel
      data-player-id="<%= player.id %>"
      data-active-season-id="<%= activeSeasonId %>"
      data-active-season-label="<%= activeSeasonLabel %>"
      data-team-label="<%= playerTeamLabel %>"
      data-can-edit="<%= canEditSeasonRecommendations ? 'true' : 'false' %>"
    >
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
          <div>
            <h2 class="h5 mb-1">Próxima temporada</h2>
            <p class="text-muted mb-0">Recomendación rápida para coordinación deportiva y seguimiento del jugador.</p>
          </div>
          <span class="badge rounded-pill text-bg-light border season-recommendation-card__eyebrow">PlayerTrack</span>
        </div>

        <div class="row g-4">
          <div class="col-lg-5">
            <div class="season-recommendation-current" data-season-recommendation-current>
              <div class="season-recommendation-empty text-muted">Cargando recomendación actual…</div>
            </div>
          </div>

          <div class="col-lg-7">
            <form class="season-recommendation-form" data-season-recommendation-form>
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="seasonRecommendationSeason" class="form-label">Temporada</label>
                  <select id="seasonRecommendationSeason" name="seasonId" class="form-select" required data-season-recommendation-season></select>
                </div>
                <div class="col-md-6">
                  <label for="seasonRecommendationStatus" class="form-label">Estado</label>
                  <select id="seasonRecommendationStatus" name="status" class="form-select" data-season-recommendation-status>
                    <option value="proposed">Proposed</option>
                    <option value="in_review">In review</option>
                    <option value="validated">Validated</option>
                    <option value="discarded">Discarded</option>
                  </select>
                </div>
                <div class="col-12">
                  <label for="seasonRecommendationTeamLabel" class="form-label">Equipo recomendado</label>
                  <input
                    id="seasonRecommendationTeamLabel"
                    name="recommendedTeamLabel"
                    type="text"
                    class="form-control"
                    maxlength="150"
                    placeholder="Ej. Juvenil A / Cadete Preferente"
                    value="<%= playerTeamLabel %>"
                    required
                    data-season-recommendation-team
                  />
                </div>
                <div class="col-12">
                  <label for="seasonRecommendationNotes" class="form-label">Notas</label>
                  <textarea
                    id="seasonRecommendationNotes"
                    name="notes"
                    rows="3"
                    class="form-control"
                    placeholder="Motivo de la recomendación, contexto competitivo o puntos a revisar"
                    data-season-recommendation-notes
                  ></textarea>
                </div>
              </div>

              <div class="d-flex flex-wrap gap-2 align-items-center mt-3">
                <button type="submit" class="btn btn-primary" data-season-recommendation-submit <%= canEditSeasonRecommendations ? '' : 'disabled' %>>Guardar recomendación</button>
                <span class="small text-muted" data-season-recommendation-feedback></span>
              </div>
            </form>
            <% if (!canEditSeasonRecommendations) { %>
              <p class="small text-muted mt-3 mb-0">Solo administradores pueden guardar recomendaciones de próxima temporada.</p>
            <% } %>
          </div>
        </div>

        <div class="mt-4">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h3 class="h6 mb-0">Histórico</h3>
            <span class="small text-muted" data-season-recommendation-history-count></span>
          </div>
          <div class="season-recommendation-history" data-season-recommendation-history>
            <div class="season-recommendation-empty text-muted">Cargando histórico…</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <% if (scoutingPlayersEnabled && hasEvaluationHistory) { %>
    <section class="mb-4">
      <div class="card pmv-surface-card shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div>
              <h2 class="h5 mb-1">Evolución simple</h2>
              <p class="text-muted mb-0">Vista rápida del rendimiento medio del jugador por áreas.</p>
            </div>
            <% if (trendSummary) { %>
              <div class="small text-muted">
                Últimas medias: <strong><%= trendSummary.latestScore.toFixed(2) %></strong> frente a <strong><%= trendSummary.previousScore.toFixed(2) %></strong>
              </div>
            <% } %>
          </div>

          <div class="row g-4 align-items-stretch">
            <div class="col-lg-6">
              <div class="chart-panel h-100">
                <canvas id="playerRadarChart" height="280"></canvas>
              </div>
            </div>
            <div class="col-lg-6">
              <div class="row g-3">
                <% analytics.areaEntries.forEach((area) => { %>
                  <div class="col-md-6">
                    <div class="card pmv-list-card border-0 h-100">
                      <div class="card-body">
                        <h3 class="h6 mb-3"><%= area.label %></h3>
                        <% area.metrics.slice(0, 4).forEach((metric) => { %>
                          <div class="d-flex justify-content-between border-bottom py-2">
                            <span><%= metric.label %></span>
                            <strong><%= metric.average.toFixed(2) %></strong>
                          </div>
                        <% }) %>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  <% } %>

  <% if (scoutingPlayersEnabled) { %>
    <section class="mb-4">
      <div class="card pmv-surface-card shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div>
              <h2 class="h5 mb-1">Jugador vs media del equipo</h2>
              <p class="text-muted mb-0">Comparativa simple del jugador frente al nivel medio actual del equipo en temporada activa.</p>
            </div>
          </div>

          <% if (!playerBenchmark || !playerBenchmark.isReady) { %>
            <p class="mb-0 text-muted"><%= (playerBenchmark && playerBenchmark.message) || 'Aún no hay suficientes evaluaciones para comparar al jugador con su equipo.' %></p>
          <% } else { %>
            <div class="row g-4 mb-4">
              <div class="col-md-4">
                <div class="pmv-inline-stat h-100">
                  <div class="small text-uppercase text-muted">Media global jugador</div>
                  <div class="h3 mb-1"><%= playerBenchmark.playerGlobalAverage != null ? playerBenchmark.playerGlobalAverage.toFixed(2) : '-' %></div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="pmv-inline-stat h-100">
                  <div class="small text-uppercase text-muted">Media global equipo</div>
                  <div class="h3 mb-1"><%= playerBenchmark.teamGlobalAverage != null ? playerBenchmark.teamGlobalAverage.toFixed(2) : '-' %></div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="pmv-inline-stat h-100">
                  <div class="small text-uppercase text-muted">Diferencia global</div>
                  <div class="h3 mb-1 <%= playerBenchmark.globalDifference > 0 ? 'text-success' : playerBenchmark.globalDifference < 0 ? 'text-danger' : '' %>">
                    <%= playerBenchmark.globalDifference != null ? `${playerBenchmark.globalDifference > 0 ? '+' : ''}${playerBenchmark.globalDifference.toFixed(2)}` : '-' %>
                  </div>
                </div>
              </div>
            </div>

            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th>Área</th>
                    <th class="text-end">Jugador</th>
                    <th class="text-end">Equipo</th>
                    <th class="text-end">Diferencia</th>
                  </tr>
                </thead>
                <tbody>
                  <% playerBenchmark.areaComparisons.forEach((area) => { %>
                    <tr>
                      <td><%= area.label %></td>
                      <td class="text-end fw-semibold"><%= area.playerAverage != null ? area.playerAverage.toFixed(2) : '-' %></td>
                      <td class="text-end"><%= area.teamAverage != null ? area.teamAverage.toFixed(2) : '-' %></td>
                      <td class="text-end <%= area.difference > 0 ? 'text-success' : area.difference < 0 ? 'text-danger' : 'text-muted' %>">
                        <%= area.difference != null ? `${area.difference > 0 ? '+' : ''}${area.difference.toFixed(2)}` : '-' %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <% if (playerBenchmark.strengthsText || playerBenchmark.improvementText) { %>
              <div class="pmv-note-box mt-4">
                <% if (playerBenchmark.strengthsText) { %>
                  <p class="mb-2"><%= playerBenchmark.strengthsText %></p>
                <% } %>
                <% if (playerBenchmark.improvementText) { %>
                  <p class="mb-0"><%= playerBenchmark.improvementText %></p>
                <% } %>
              </div>
            <% } %>
          <% } %>
        </div>
      </div>
    </section>
  <% } %>

  <section class="mb-4">
    <div class="row g-4">
      <div class="col-xl-6">
        <div class="card pmv-list-card shadow-sm h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
              <h2 class="h5 mb-0">Historial de evaluaciones</h2>
              <% if (scoutingPlayersEnabled) { %>
                <div class="d-flex gap-2 flex-wrap">
                  <a href="/evaluations/new?team_id=<%= player.current_team_id || '' %>&player_id=<%= player.id %>" class="btn btn-sm btn-primary">Nueva evaluación</a>
                  <a href="/players/<%= player.id %>/evaluations" class="btn btn-sm btn-outline-secondary">Ver historial</a>
                </div>
              <% } %>
            </div>

            <% if (!scoutingPlayersEnabled) { %>
              <div class="border rounded-3 bg-light p-3">
                <p class="fw-semibold mb-2">Disponible con el módulo Scouting Players</p>
                <p class="text-muted mb-0">En este bloque aparecerá el histórico de evaluaciones del jugador.</p>
              </div>
            <% } else if (!recentEvaluations.length) { %>
              <p class="text-muted mb-0">No hay evaluaciones registradas para este jugador.</p>
            <% } else { %>
              <div class="list-group list-group-flush pmv-record-list">
                <% recentEvaluations.forEach((evaluation) => { %>
                  <a href="/evaluations/<%= evaluation.id %>" class="list-group-item list-group-item-action px-0">
                    <div class="d-flex justify-content-between gap-3">
                      <div>
                        <div class="fw-semibold"><%= evaluation.title || 'Evaluación manual' %></div>
                        <div class="small text-muted"><%= evaluation.team_name || '-' %> · <%= evaluation.author_name || 'Sin autor' %></div>
                      </div>
                      <div class="text-end">
                        <div><%= evaluation.evaluation_date ? new Date(evaluation.evaluation_date).toISOString().slice(0, 10) : '' %></div>
                        <div class="small text-muted"><%= evaluation.overall_score !== null ? Number(evaluation.overall_score).toFixed(2) : '-' %></div>
                      </div>
                    </div>
                  </a>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="col-xl-6">
        <div class="card pmv-list-card shadow-sm h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
              <h2 class="h5 mb-0">Historial de informes</h2>
              <% if (scoutingPlayersEnabled) { %>
                <div class="d-flex gap-2 flex-wrap">
                  <a href="/reports/new?team_id=<%= player.current_team_id || '' %>&player_id=<%= player.id %>" class="btn btn-sm btn-primary">Nuevo informe</a>
                  <a href="/reports" class="btn btn-sm btn-outline-secondary">Ver listado</a>
                </div>
              <% } %>
            </div>

