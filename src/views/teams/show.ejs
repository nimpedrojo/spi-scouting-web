<div class="mb-4">
  <a href="/teams" class="text-decoration-none text-muted d-inline-flex align-items-center gap-2">
    <span aria-hidden="true">←</span>
    <span>Volver a Plantillas</span>
  </a>
</div>

<div class="team-detail-hero card shadow-sm mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-4">
      <div class="d-flex align-items-start gap-3">
        <div class="team-detail-hero__crest">SR</div>
        <div>
          <h1 class="team-detail-hero__title mb-2"><%= team.name %></h1>
          <div class="d-flex flex-wrap gap-2">
            <span class="badge text-bg-light"><%= team.season_name %></span>
            <span class="badge text-bg-primary"><%= team.category_name %></span>
            <span class="badge text-bg-light"><%= team.section_name %></span>
            <span class="badge text-bg-light"><%= team.players.length %> jugadores</span>
          </div>
          <div class="small text-muted mt-2"><%= team.club_name %></div>
        </div>
      </div>

      <div class="d-flex gap-2 flex-wrap">
        <a href="/evaluations?team_id=<%= team.id %>" class="btn btn-outline-secondary">Evaluaciones</a>
        <a href="/season-forecast/team/<%= team.id %>" class="btn btn-outline-secondary">Previsión 26/27</a>
        <% if (canManageMultipleTeams) { %>
          <a href="/teams/<%= team.id %>/edit" class="btn btn-outline-secondary">Editar</a>
        <% } %>
        <% if (canManageMultipleTeams && team.source === 'processiq' && team.external_id) { %>
          <form method="POST" action="/teams/<%= team.id %>/import-players/processiq" class="d-inline">
            <button type="submit" class="btn btn-outline-dark">Cargar jugadores ProcessIQ</button>
          </form>
        <% } %>
        <a href="/admin/players/new" class="btn btn-primary">Añadir jugador</a>
      </div>
    </div>
  </div>
</div>

<div class="team-detail-tabs mb-4">
  <a href="/teams/<%= team.id %>?view=list" class="team-detail-tab <%= viewMode === 'list' ? 'active' : '' %>">Plantilla</a>
  <a href="/season-forecast/team/<%= team.id %>" class="team-detail-tab">Previsión 26/27</a>
  <a href="/evaluations?team_id=<%= team.id %>" class="team-detail-tab">Evaluaciones</a>
</div>

<div class="row g-4">
  <div class="col-xl-4">
    <div class="card shadow-sm h-100 team-detail-panel">
      <div class="card-body">
        <div class="team-detail-panel__heading">Cobertura de posiciones</div>

        <div class="team-coverage-pitch">
          <div class="team-coverage-pitch__field">
            <svg class="team-coverage-pitch__svg" viewBox="0 0 320 440" aria-hidden="true">
              <defs>
                <linearGradient id="teamPitchGrass" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" stop-color="#1d7a3f" />
                  <stop offset="100%" stop-color="#166236" />
                </linearGradient>
              </defs>
              <rect x="0" y="0" width="320" height="440" rx="16" fill="url(#teamPitchGrass)" />
              <rect x="14" y="14" width="292" height="412" rx="10" fill="none" stroke="rgba(255,255,255,0.92)" stroke-width="3" />
              <line x1="14" y1="220" x2="306" y2="220" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <circle cx="160" cy="220" r="34" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <circle cx="160" cy="220" r="2.5" fill="rgba(255,255,255,0.92)" />

              <rect x="72" y="14" width="176" height="74" rx="2" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <rect x="112" y="14" width="96" height="28" rx="2" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <circle cx="160" cy="88" r="2.5" fill="rgba(255,255,255,0.92)" />
              <path d="M128 88a32 32 0 0 0 64 0" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />

              <rect x="72" y="352" width="176" height="74" rx="2" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <rect x="112" y="398" width="96" height="28" rx="2" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
              <circle cx="160" cy="352" r="2.5" fill="rgba(255,255,255,0.92)" />
              <path d="M128 352a32 32 0 0 1 64 0" fill="none" stroke="rgba(255,255,255,0.72)" stroke-width="2.5" />
            </svg>
            <% const coverageMap = new Map((team.coverageSummary || []).map((entry) => [entry.code, entry.count])); %>
            <% ['DEL', 'EI', 'MP', 'ED', 'II', 'MC', 'ID', 'LI', 'CENTRAL', 'LD', 'POR'].forEach((position) => { %>
              <% const count = coverageMap.get(position) || 0; %>
              <div class="team-coverage-pitch__marker pos-<%= position.toLowerCase() %> <%= count ? 'is-covered' : 'is-empty' %>">
                <strong><%= count || '-' %></strong>
                <span><%= position %></span>
              </div>
            <% }) %>
          </div>
        </div>

        <% if (team.coverageSummary && team.coverageSummary.length) { %>
          <div class="row g-2 mt-3">
            <% team.coverageSummary.forEach((entry) => { %>
              <div class="col-6">
                <div class="team-coverage-chip">
                  <span class="team-coverage-chip__code"><%= entry.code %></span>
                  <strong><%= entry.count %></strong>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-muted small mt-3 mb-0">Todavía no hay posiciones registradas en esta plantilla.</p>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-xl-8">
    <div class="card shadow-sm h-100 team-detail-panel">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
          <div>
            <h2 class="h4 mb-0">Plantilla — <%= team.name %></h2>
          </div>
          <div class="d-flex gap-2 flex-wrap align-items-center">
            <span class="badge text-bg-light"><%= team.players.length %> jugadores</span>
            <div class="btn-group" role="group" aria-label="Modo de vista de jugadores">
              <a href="/teams/<%= team.id %>?view=list" class="btn btn-sm btn-outline-secondary <%= viewMode === 'list' ? 'active' : '' %>">Lista</a>
              <a href="/teams/<%= team.id %>?view=cards" class="btn btn-sm btn-outline-secondary <%= viewMode === 'cards' ? 'active' : '' %>">Tarjetas</a>
            </div>
          </div>
        </div>

        <% if (!team.players.length) { %>
          <p class="mb-0 text-muted">No hay jugadores asignados a esta plantilla.</p>
        <% } else if (viewMode === 'cards') { %>
          <div class="row g-3">
            <% team.players.forEach((player, index) => { %>
              <div class="col-md-6">
                <div class="team-player-card h-100">
                  <div class="team-player-card__rank"><%= index + 1 %></div>
                  <div class="team-player-card__body">
                    <div class="d-flex justify-content-between gap-3">
                      <div>
                        <div class="team-player-card__name"><%= player.full_name %></div>
                        <div class="small text-muted"><%= player.birth_year || '-' %></div>
                      </div>
                      <div class="team-player-card__meta">
                        <span class="badge text-bg-primary">#<%= player.dorsal || '-' %></span>
                      </div>
                    </div>
                    <div class="d-flex gap-2 flex-wrap mt-3">
                      <span class="badge rounded-pill text-bg-warning"><%= player.primary_position || 'Sin pos.' %></span>
                      <span class="badge rounded-pill text-bg-light"><%= player.positions || '-' %></span>
                    </div>
                    <div class="d-flex gap-2 mt-3">
                      <a href="/players/<%= player.id %>" class="btn btn-sm btn-outline-secondary">Perfil</a>
                      <a href="/admin/players/<%= player.id %>/edit" class="btn btn-sm btn-primary">Editar</a>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle team-detail-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Jugador</th>
                  <th>Año</th>
                  <th>Pos.</th>
                  <th>Posiciones</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% team.players.forEach((player, index) => { %>
                  <tr>
                    <td>
                      <span class="team-detail-table__rank"><%= player.dorsal || index + 1 %></span>
                    </td>
                    <td>
                      <div class="fw-semibold"><%= player.full_name %></div>
                      <div class="small text-muted"><%= player.laterality || '-' %></div>
                    </td>
                    <td><%= player.birth_year || '-' %></td>
                    <td><span class="badge rounded-pill text-bg-warning"><%= player.primary_position || '-' %></span></td>
                    <td><%= player.positions || '-' %></td>
                    <td class="text-end">
                      <div class="d-flex justify-content-end gap-2">
                        <a href="/players/<%= player.id %>" class="btn btn-sm btn-outline-secondary">Perfil</a>
                        <a href="/admin/players/<%= player.id %>/edit" class="btn btn-sm btn-primary">Editar</a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
