<div
  id="processiq-player-loading-state"
  class="alert alert-info d-none align-items-center gap-2 mb-4"
  role="status"
  aria-live="polite"
>
  <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
  <span>Sincronizando jugadores desde ProcessIQ. Esta operación puede tardar unos segundos.</span>
</div>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div>
    <p class="text-muted mb-0">
      <%= clubName %>
      <% if (activeSeason) { %>
        · Contexto <strong><%= activeSeason.name %></strong>
      <% } %>
    </p>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <form method="POST" action="/teams/import-players/processiq" class="d-inline" data-processiq-player-loading-form>
      <% if (selectedClubId) { %>
        <input type="hidden" name="club_id" value="<%= selectedClubId %>">
      <% } %>
      <input type="hidden" name="section" value="<%= activeSection %>">
      <input type="hidden" name="category" value="<%= activeCategory %>">
      <button type="submit" class="btn btn-outline-dark" data-loading-button data-loading-text="Cargando visibles...">
        <span class="button-label">Cargar jugadores visibles</span>
      </button>
    </form>
    <a href="/teams/import/processiq<%= selectedClubId ? ('?club_id=' + encodeURIComponent(selectedClubId)) : '' %>" class="btn btn-outline-secondary">Importar desde ProcessIQ</a>
    <a href="/teams/new<%= selectedClubId ? ('?club_id=' + encodeURIComponent(selectedClubId)) : '' %>" class="btn btn-primary">Nueva plantilla</a>
  </div>
</div>

<% if (seasonView && seasonView.seasons && seasonView.seasons.length) { %>
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <form method="GET" action="/teams" class="row g-3 align-items-end">
        <% if (selectedClubId) { %>
          <input type="hidden" name="club_id" value="<%= selectedClubId %>">
        <% } %>
        <input type="hidden" name="section" value="<%= activeSection %>">
        <input type="hidden" name="category" value="<%= activeCategory %>">
        <div class="col-md-8">
          <label for="teamsSeasonSelector" class="form-label">Temporada</label>
          <select id="teamsSeasonSelector" name="season_id" class="form-select">
            <% seasonView.seasons.forEach((season) => { %>
              <option value="<%= season.id %>" <%= String(seasonView.selectedSeasonId || '') === String(season.id) ? 'selected' : '' %>>
                <%= season.name %><%= season.is_active ? ' · Activa' : '' %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
          <button type="submit" class="btn btn-outline-secondary">Cambiar temporada</button>
        </div>
      </form>
    </div>
  </div>
<% } %>

<div class="card shadow-sm border-0 bg-light-subtle mb-4">
  <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
      <h2 class="h6 mb-1">Sincronización de equipos</h2>
      <p class="text-muted small mb-0">
        Importa plantillas desde <code>api.processiq.es/teams</code>. Solo se crean equipos nuevos del club activo.
      </p>
    </div>
    <a href="/teams/import/processiq<%= selectedClubId ? ('?club_id=' + encodeURIComponent(selectedClubId)) : '' %>" class="btn btn-sm btn-outline-dark">Abrir previsualización</a>
  </div>
</div>

<ul class="nav nav-tabs mb-3">
  <% availableSections.forEach((sectionName) => { %>
    <li class="nav-item">
      <a
        class="nav-link <%= activeSection === sectionName ? 'active' : '' %>"
        href="/teams?section=<%= encodeURIComponent(sectionName) %><%= activeCategory ? '&category=' + encodeURIComponent(activeCategory) : '' %><%= seasonView && seasonView.selectedSeasonId ? '&season_id=' + encodeURIComponent(seasonView.selectedSeasonId) : '' %><%= selectedClubId ? '&club_id=' + encodeURIComponent(selectedClubId) : '' %>"
      >
        <%= sectionName %>
      </a>
    </li>
  <% }) %>
</ul>

<div class="d-flex flex-wrap gap-2 mb-4">
  <a
    href="/teams?section=<%= encodeURIComponent(activeSection) %><%= seasonView && seasonView.selectedSeasonId ? '&season_id=' + encodeURIComponent(seasonView.selectedSeasonId) : '' %><%= selectedClubId ? '&club_id=' + encodeURIComponent(selectedClubId) : '' %>"
    class="btn btn-sm <%= !activeCategory ? 'btn-primary' : 'btn-outline-secondary' %> filter-chip"
  >
    Todas
  </a>
  <% availableCategories.forEach((categoryName) => { %>
    <a
      href="/teams?section=<%= encodeURIComponent(activeSection) %>&category=<%= encodeURIComponent(categoryName) %><%= seasonView && seasonView.selectedSeasonId ? '&season_id=' + encodeURIComponent(seasonView.selectedSeasonId) : '' %><%= selectedClubId ? '&club_id=' + encodeURIComponent(selectedClubId) : '' %>"
      class="btn btn-sm <%= activeCategory === categoryName ? 'btn-primary' : 'btn-outline-secondary' %> filter-chip"
    >
      <%= categoryName %>
    </a>
  <% }) %>
</div>

<%
  const sectionGroups = groupedTeams[activeSection] || {};
  const groupKeys = Object.keys(sectionGroups);
%>

<% if (!groupKeys.length) { %>
  <div class="card shadow-sm">
    <div class="card-body">
      <p class="mb-0">No hay plantillas registradas para los filtros actuales.</p>
    </div>
  </div>
<% } %>

<% groupKeys.forEach((categoryName) => { %>
  <section class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="h5 mb-0"><%= categoryName %></h2>
      <span class="badge text-bg-light"><%= sectionGroups[categoryName].length %> equipos</span>
    </div>

    <div class="row g-4">
      <% sectionGroups[categoryName].forEach((team) => { %>
        <div class="col-xl-4 col-lg-6">
          <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
              <div class="d-flex justify-content-between gap-3 align-items-start mb-3">
                <div>
                  <h3 class="h5 mb-1"><%= team.name %></h3>
                  <div class="text-muted small">
                    <%= team.season_name %> · <%= team.category_name %>
                  </div>
                </div>
                <span class="badge text-bg-primary"><%= team.player_count %> jugadores</span>
              </div>

              <div class="team-card-summary mb-3">
                <% if (team.player_count) { %>
                  <div class="team-card-summary-grid">
                    <article class="team-summary-stat">
                      <span class="team-summary-stat__label">Año base</span>
                      <strong class="team-summary-stat__value"><%= team.summary.birthYearLabel %></strong>
                      <span class="team-summary-stat__detail"><%= team.summary.birthYearDetail %></span>
                    </article>

                    <article class="team-summary-stat">
                      <span class="team-summary-stat__label">Cobertura</span>
                      <strong class="team-summary-stat__value"><%= team.summary.coverageLabel %></strong>
                      <span class="team-summary-stat__detail"><%= team.summary.coverageDetail %></span>
                    </article>
                  </div>

                  <div class="team-summary-lines">
                    <div class="team-summary-line">
                      <span>POR</span>
                      <strong><%= team.summary.lineDistribution.goalkeepers %></strong>
                    </div>
                    <div class="team-summary-line">
                      <span>DEF</span>
                      <strong><%= team.summary.lineDistribution.defense %></strong>
                    </div>
                    <div class="team-summary-line">
                      <span>MED</span>
                      <strong><%= team.summary.lineDistribution.midfield %></strong>
                    </div>
                    <div class="team-summary-line">
                      <span>ATA</span>
                      <strong><%= team.summary.lineDistribution.attack %></strong>
                    </div>
                  </div>

                  <div class="team-laterality-card">
                    <div>
                      <div class="team-summary-stat__label mb-1">Lateralidad</div>
                      <div class="team-laterality-legend">
                        <span><i class="team-laterality-dot team-laterality-dot--right"></i> Diestros <strong><%= team.summary.laterality.counts.right %></strong></span>
                        <span><i class="team-laterality-dot team-laterality-dot--left"></i> Zurdos <strong><%= team.summary.laterality.counts.left %></strong></span>
                        <span><i class="team-laterality-dot team-laterality-dot--both"></i> Ambi <strong><%= team.summary.laterality.counts.both %></strong></span>
                      </div>
                    </div>
                    <div
                      class="team-laterality-chart"
                      style="background:<%= team.summary.laterality.chartStyle %>;"
                      aria-label="Distribución de lateralidad"
                      role="img"
                    ></div>
                  </div>
                <% } else { %>
                  <p class="text-muted small mb-0">Sin jugadores asignados todavía.</p>
                <% } %>
              </div>

              <div class="mt-auto d-flex gap-2 flex-wrap">
                <a href="/teams/<%= team.id %>?season_id=<%= encodeURIComponent((seasonView && seasonView.selectedSeasonId) || '') %><%= selectedClubId ? ('&club_id=' + encodeURIComponent(selectedClubId)) : '' %>" class="btn btn-sm btn-primary">Abrir ficha</a>
                <% if (team.source === 'processiq' && team.external_id) { %>
                  <form method="POST" action="/teams/<%= team.id %>/import-players/processiq" data-processiq-player-loading-form>
                    <% if (selectedClubId) { %>
                      <input type="hidden" name="club_id" value="<%= selectedClubId %>">
                    <% } %>
                    <button type="submit" class="btn btn-sm btn-outline-dark" data-loading-button data-loading-text="Cargando...">
                      <span class="button-label">Cargar jugadores</span>
                    </button>
                  </form>
                <% } %>
                <a href="/teams/<%= team.id %>/edit<%= selectedClubId ? ('?club_id=' + encodeURIComponent(selectedClubId)) : '' %>" class="btn btn-sm btn-outline-secondary">Editar</a>
                <form
                  method="POST"
                  action="/teams/<%= team.id %>/delete"
                  onsubmit="return confirm('¿Seguro que quieres eliminar esta plantilla?');"
                >
                  <% if (selectedClubId) { %>
                    <input type="hidden" name="club_id" value="<%= selectedClubId %>">
                  <% } %>
                  <button type="submit" class="btn btn-sm btn-outline-danger">Borrar</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </section>
<% }) %>

<script>
  (() => {
    const loadingState = document.getElementById('processiq-player-loading-state');
    const forms = document.querySelectorAll('[data-processiq-player-loading-form]');

    if (!loadingState || !forms.length) {
      return;
    }

    forms.forEach((form) => {
      form.addEventListener('submit', () => {
        loadingState.classList.remove('d-none');
        loadingState.classList.add('d-flex');

        const button = form.querySelector('[data-loading-button]');
        if (button) {
          const label = button.querySelector('.button-label');
          const loadingText = button.getAttribute('data-loading-text') || 'Cargando...';
          button.disabled = true;
          if (label) {
            label.textContent = loadingText;
          }
          if (!button.querySelector('.spinner-border')) {
            button.insertAdjacentHTML('afterbegin', '<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>');
          }
        }
      });
    });
  })();
</script>
