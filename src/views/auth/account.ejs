<h1 class="mb-4">Mi cuenta</h1>

<form method="POST" action="/account" class="col-md-6">
  <div class="mb-3">
    <label for="name" class="form-label">Nombre</label>
    <input
      type="text"
      class="form-control"
      id="name"
      name="name"
      value="<%= user.name || '' %>"
      required
    />
  </div>

  <div class="mb-3">
    <label for="email" class="form-label">Email</label>
    <input
      type="email"
      class="form-control"
      id="email"
      name="email"
      value="<%= user.email || '' %>"
      required
    />
  </div>

  <hr class="my-4" />

  <% if (isSuperAdmin) { %>
    <h5>Administrador de plataforma</h5>
    <div class="alert alert-light border">
      Este usuario es <strong>superadmin</strong> y actúa como administrador de la plataforma. No trabaja con un club ni un equipo activos por defecto.
      Cuando necesites operar sobre un club concreto, selecciónalo explícitamente desde las pantallas de administración de plataforma o de club.
    </div>
  <% } else { %>
    <h5>Valores por defecto para informes</h5>
    <p class="text-muted">
      Estos valores se usarán como Club y Equipo por defecto al crear nuevos informes.
      El equipo por defecto ahora se selecciona desde las Plantillas v2 del club.
    </p>

    <div class="mb-3">
      <a href="/teams" class="btn btn-outline-secondary btn-sm">
        Ver Plantillas
      </a>
      <a href="/teams/new" class="btn btn-outline-secondary btn-sm ms-2">
        Crear equipo v2
      </a>
    </div>

    <div class="mb-3">
      <label for="default_club" class="form-label">Club por defecto</label>
      <% const fixedClubName = (resolvedClub && resolvedClub.name) || user.club_name || ''; %>
      <% if (fixedClubName) { %>
        <input
          type="text"
          class="form-control"
          id="default_club"
          value="<%= fixedClubName %>"
          readonly
        />
        <input type="hidden" name="default_club" value="<%= fixedClubName %>" />
      <% } else { %>
      <input
        type="text"
        class="form-control"
        id="default_club"
        name="default_club"
        value="<%= user.default_club || '' %>"
      />
      <% } %>
    </div>

    <div class="mb-3">
      <label for="default_team_id" class="form-label">Equipo por defecto</label>
      <select
        class="form-select"
        id="default_team_id"
        name="default_team_id"
      >
        <% const hasTeams = Array.isArray(teams) && teams.length > 0; %>
        <% const currentTeamId = user.default_team_id || ''; %>
        <option value="">-- Selecciona equipo --</option>
        <% if (hasTeams) { %>
          <% teams.forEach(function (t) { %>
            <option value="<%= t.id %>" <%= String(t.id) === String(currentTeamId) ? 'selected' : '' %>>
              <%= t.label %>
            </option>
          <% }) %>
        <% } else { %>
          <option value="" selected>Sin equipos v2 configurados todavía</option>
        <% } %>
      </select>
      <% if (!hasTeams) { %>
        <div class="form-text">
          Crea primero equipos en Plantillas para poder seleccionar uno aquí.
        </div>
      <% } %>
    </div>
  <% } %>

  <hr class="my-4" />

  <h5>Integración ProcessIQ</h5>
  <p class="text-muted">
    Estas credenciales se usarán para obtener el token en <code>/auth/token</code> antes de cargar la previsualización de equipos.
  </p>

  <div class="mb-3">
    <label for="processiq_username" class="form-label">Usuario ProcessIQ</label>
    <input
      type="text"
      class="form-control"
      id="processiq_username"
      name="processiq_username"
      value="<%= user.processiq_username || '' %>"
      placeholder="Usuario de api.processiq.es"
    />
  </div>

  <div class="mb-3">
    <label for="processiq_password" class="form-label">Contraseña ProcessIQ</label>
    <input
      type="password"
      class="form-control"
      id="processiq_password"
      name="processiq_password"
      value=""
      placeholder="<%= user.processiq_password ? 'Dejar vacío para conservar la actual' : 'Contraseña de api.processiq.es' %>"
    />
    <div class="form-text">
      <% if (user.processiq_password) { %>
        Ya hay una contraseña guardada. Si dejas este campo vacío, se mantiene la actual.
      <% } else { %>
        Guarda aquí la contraseña que se usará para autenticar contra ProcessIQ.
      <% } %>
    </div>
  </div>

  <button type="submit" class="btn btn-sr-primary">Guardar cambios</button>
</form>
