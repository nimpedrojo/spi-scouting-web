<% const isPmvMode = productModeInfo && productModeInfo.isPmvPlayerTracking; %>
<header class="app-topbar">
  <div>
    <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
      <h1 class="h4 mb-0"><%= pageTitle || 'SoccerProcessIQ Suite' %></h1>
      <% if (productModeInfo && productModeInfo.effectiveMeta && !isPmvMode) { %>
        <span class="badge text-bg-light border"><%= productModeInfo.effectiveMeta.label %></span>
      <% } %>
    </div>
    <% if (typeof pageDescription !== 'undefined' && pageDescription) { %>
      <p class="text-muted mb-0"><%= pageDescription %></p>
    <% } %>
  </div>

  <% if (currentUser) { %>
    <div class="d-flex align-items-center gap-3">
      <a href="/account" class="btn btn-outline-secondary btn-sm">Mi cuenta</a>
      <form method="POST" action="/logout">
        <button class="btn btn-primary btn-sm" type="submit">Salir</button>
      </form>
    </div>
  <% } %>
</header>
