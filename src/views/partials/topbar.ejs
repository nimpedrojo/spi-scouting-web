<%
  const isPmvMode = productModeInfo && productModeInfo.isPmvPlayerTracking;
  const isAdminUser = currentUser && (currentUser.role === 'admin' || currentUser.role === 'superadmin');
  const adminHref = currentUser && currentUser.role === 'superadmin' ? '/admin/platform' : '/admin/club';
  const adminLabel = 'Administración';
  const headerTitle = isPmvMode ? 'Seguimiento de jugadores' : 'SoccerProcessIQ Suite';
  const headerSubtitle = isPmvMode ? 'Trabajo diario del club' : 'Modular Football Club Platform';
%>
<header class="app-topbar">
  <div class="app-topbar__brand-wrap">
    <a href="/dashboard" class="app-topbar__brand text-decoration-none text-reset">
      <img src="/img/soccerreport-logo.png" alt="SoccerProcessIQ Suite" class="app-topbar__logo" />
      <div>
        <div class="app-topbar__brand-title"><%= headerTitle %></div>
        <div class="app-topbar__brand-subtitle"><%= headerSubtitle %></div>
      </div>
    </a>
    <% if (productModeInfo && productModeInfo.effectiveMeta && !isPmvMode) { %>
      <span class="badge text-bg-light border"><%= productModeInfo.effectiveMeta.label %></span>
    <% } %>
  </div>

  <% if (currentUser) { %>
    <div class="d-flex align-items-center gap-2 flex-wrap app-topbar__actions">
      <a href="/account" class="btn btn-outline-secondary btn-sm">Ver mi perfil</a>
      <% if (isAdminUser) { %>
        <a href="<%= adminHref %>" class="btn btn-outline-secondary btn-sm"><%= adminLabel %></a>
      <% } %>
      <form method="POST" action="/logout">
        <button class="btn btn-light btn-sm" type="submit">Salir</button>
      </form>
    </div>
  <% } %>
</header>
