<%
  const managementItems = [
    { label: 'Panel general', href: '/dashboard' },
    { label: 'Plantillas', href: '/teams' },
    { label: 'Previsión 2026/27', href: '/season-forecast' },
    { label: 'Comparativa 26/27', href: '/season-comparison' },
    { label: 'Informes', href: '/reports' },
    { label: 'Evaluaciones', href: '/evaluations' },
    { label: 'Scouting', href: '/reports/new' },
  ];
  const adminItems = [
    { label: 'Plantillas eval.', href: '/evaluation-templates' },
    { label: 'Jugadores', href: '/admin/players', adminOnly: true },
    { label: 'Admin. equipos', href: '/admin/club', adminOnly: true },
    { label: 'Usuarios', href: '/admin/users', adminOnly: true },
    { label: 'Clubes', href: '/clubs', adminOnly: true },
  ];
  const isAdminUser = currentUser && (currentUser.role === 'admin' || currentUser.role === 'superadmin');
  const visibleAdminItems = adminItems.filter((item) => !item.adminOnly || isAdminUser);
  const isItemActive = (item) => item.href !== '#' && activeRoute && (activeRoute === item.href || activeRoute.startsWith(item.href + '/'));
%>

<aside class="app-sidebar">
  <div class="app-sidebar__brand">
    <a href="/dashboard" class="text-decoration-none text-reset d-flex align-items-center gap-2">
      <img src="/img/soccerreport-logo.png" alt="SoccerReport" class="app-sidebar__logo" />
      <div>
        <div class="app-sidebar__title">SoccerReport</div>
        <div class="app-sidebar__subtitle">Academy OS</div>
      </div>
    </a>
  </div>

  <div class="app-sidebar__meta">
    <div class="small text-uppercase text-muted">Club</div>
    <div class="fw-semibold"><%= activeClubName || 'Sin club asignado' %></div>
    <div class="small text-uppercase text-muted mt-3">Temporada</div>
    <div class="fw-semibold"><%= activeSeasonLabel || 'Pendiente' %></div>
  </div>

  <nav class="nav flex-column app-sidebar__nav">
    <div class="small text-uppercase text-muted mt-2 mb-1 px-3">Gestión</div>
    <% managementItems.forEach((item) => { %>
      <% const isDisabled = item.href === '#'; %>
      <% const isActive = isItemActive(item); %>
      <a
        href="<%= item.href %>"
        class="nav-link <%= isActive ? 'active' : '' %> <%= isDisabled ? 'disabled' : '' %>"
        <%= isDisabled ? 'tabindex="-1" aria-disabled="true"' : '' %>
      >
        <%= item.label %>
      </a>
    <% }) %>

    <% if (visibleAdminItems.length) { %>
      <div class="small text-uppercase text-muted mt-3 mb-1 px-3">Administración</div>
      <% visibleAdminItems.forEach((item) => { %>
        <% const isDisabled = item.href === '#'; %>
        <% const isActive = isItemActive(item); %>
        <a
          href="<%= item.href %>"
          class="nav-link <%= isActive ? 'active' : '' %> <%= isDisabled ? 'disabled' : '' %>"
          <%= isDisabled ? 'tabindex="-1" aria-disabled="true"' : '' %>
        >
          <%= item.label %>
        </a>
      <% }) %>
    <% } %>
  </nav>

  <div class="app-sidebar__footer">
    <div class="fw-semibold"><%= currentUser ? currentUser.name : 'Invitado' %></div>
    <div class="small text-muted"><%= currentUser ? currentUser.email : '' %></div>
    <% if (currentUser) { %>
      <div class="small text-uppercase text-muted mt-2"><%= currentUser.role %></div>
    <% } %>
  </div>
</aside>
